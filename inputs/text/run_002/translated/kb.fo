      punishedArt399Basic(o).

  ! o in Offender:
    imprisonmentMaxDays(o) = 730 <=>
      punishedArt399Basic(o).

  ! o in Offender:
    fineMinEuro(o) = 50 <=>
      punishedArt399Basic(o).

  ! o in Offender:
    fineMaxEuro(o) = 200 <=>
      punishedArt399Basic(o).

  ! o in Offender:
    imprisonmentMinDays(o) = 180 <=>
      punishedArt399Premeditated(o).

  ! o in Offender:
    imprisonmentMaxDays(o) = 1095 <=>
      punishedArt399Premeditated(o).

  ! o in Offender:
    fineMinEuro(o) = 100 <=>
      punishedArt399Premeditated(o).

  ! o in Offender:
    fineMaxEuro(o) = 500 <=>
      punishedArt399Premeditated(o).

  ! o in Offender:
    imprisonmentMinDays(o) = 730 <=>
      punishedArt400Basic(o).

  ! o in Offender:
    imprisonmentMaxDays(o) = 1825 <=>
      punishedArt400Basic(o).

  ! o in Offender:
