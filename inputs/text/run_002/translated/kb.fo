      punishedArt401Basic(o).

  ! o in Offender:
    imprisonmentMaxDays(o) = 3650 <=>
      punishedArt401Basic(o).

  ! o in Offender:
    imprisonmentMinDays(o) = 3650 <=>
      punishedArt401Premeditated(o).

  ! o in Offender:
