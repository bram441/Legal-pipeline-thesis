.cache/
**/.cache/
ui/.cache
ui/run


# Evaluation outputs (reproducible; not versioned)
results/*
!results/final/
!results/final/**

# Archived evaluation runs (contents gitignored; folder marker kept)
archive/evaluation_runs/*
!archive/evaluation_runs/.gitkeep

# Optional local config overrides (secrets stay in .env)
config/local.json

# Generated artifacts inside curated benchmark inputs (keep run.json, manifest, README)
inputs/**/results.json
inputs/**/score.json
inputs/**/run_trace.txt
