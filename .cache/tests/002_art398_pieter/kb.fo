vocabulary V {
  type Person
  IntentionalWoundingOrBeating: Person -> Bool
  Premeditated: Person -> Bool
  CausesIllnessOrIncapacity: Person -> Bool
  CausesDeadlyDiseaseOrSevereHarm: Person -> Bool
  CausesDeathWithoutIntentToKill: Person -> Bool
  imprisonmentMinDays: Person -> Int
  imprisonmentMaxDays: Person -> Int
  fineMinEuro: Person -> Int
  fineMaxEuro: Person -> Int
  punishedArt398: Person -> Bool
  punishedArt399: Person -> Bool
  punishedArt400: Person -> Bool
  punishedArt401: Person -> Bool
}

theory T:V {
  ! p in Person:
    punishedArt398(p) <=> 
      IntentionalWoundingOrBeating(p) & ~CausesIllnessOrIncapacity(p) & ~CausesDeadlyDiseaseOrSevereHarm(p) & ~CausesDeathWithoutIntentToKill(p).
  
  ! p in Person:
    punishedArt399(p) <=> 
      IntentionalWoundingOrBeating(p) & CausesIllnessOrIncapacity(p) & ~CausesDeadlyDiseaseOrSevereHarm(p) & ~CausesDeathWithoutIntentToKill(p).
  
  ! p in Person:
    punishedArt400(p) <=> 
      CausesDeadlyDiseaseOrSevereHarm(p) & ~CausesDeathWithoutIntentToKill(p).
  
  ! p in Person:
    punishedArt401(p) <=> 
      CausesDeathWithoutIntentToKill(p).
  
  ! p in Person:
    imprisonmentMinDays(p) = 8 <=> 
      punishedArt398(p) & ~Premeditated(p).
  
  ! p in Person:
    imprisonmentMaxDays(p) = 183 <=> 
      punishedArt398(p) & ~Premeditated(p).

  ! p in Person:
    fineMinEuro(p) = 26 <=> 
      punishedArt398(p) & ~Premeditated(p).

  ! p in Person:
    fineMaxEuro(p) = 100 <=> 
      punishedArt398(p) & ~Premeditated(p).

  ! p in Person:
    imprisonmentMinDays(p) = 30 <=> 
      punishedArt398(p) & Premeditated(p).

  ! p in Person:
    imprisonmentMaxDays(p) = 365 <=> 
      punishedArt398(p) & Premeditated(p).

  ! p in Person:
    fineMinEuro(p) = 50 <=> 
      punishedArt398(p) & Premeditated(p).

  ! p in Person:
    fineMaxEuro(p) = 200 <=> 
      punishedArt398(p) & Premeditated(p).

  ! p in Person:
    imprisonmentMinDays(p) = 60 <=> 
      punishedArt399(p) & ~Premeditated(p).

  ! p in Person:
    imprisonmentMaxDays(p) = 730 <=> 
      punishedArt399(p) & ~Premeditated(p).

  ! p in Person:
    fineMinEuro(p) = 50 <=> 
      punishedArt399(p) & ~Premeditated(p).

  ! p in Person:
    fineMaxEuro(p) = 200 <=> 
      punishedArt399(p) & ~Premeditated(p).

  ! p in Person:
    imprisonmentMinDays(p) = 180 <=> 
      punishedArt399(p) & Premeditated(p).

  ! p in Person:
    imprisonmentMaxDays(p) = 1095 <=> 
      punishedArt399(p) & Premeditated(p).

  ! p in Person:
    fineMinEuro(p) = 100 <=> 
      punishedArt399(p) & Premeditated(p).

  ! p in Person:
    fineMaxEuro(p) = 500 <=> 
      punishedArt399(p) & Premeditated(p).

  ! p in Person:
    imprisonmentMinDays(p) = 730 <=> 
      punishedArt400(p) & ~Premeditated(p).

  ! p in Person:
    imprisonmentMaxDays(p) = 1825 <=> 
      punishedArt400(p) & ~Premeditated(p).

  ! p in Person:
    fineMinEuro(p) = 200 <=> 
      punishedArt400(p) & ~Premeditated(p).

  ! p in Person:
    fineMaxEuro(p) = 500 <=> 
      punishedArt400(p) & ~Premeditated(p).

  ! p in Person:
    imprisonmentMinDays(p) = 1825 <=> 
      punishedArt400(p) & Premeditated(p).

  ! p in Person:
    imprisonmentMaxDays(p) = 3650 <=> 
      punishedArt400(p) & Premeditated(p).

  ! p in Person:
    fineMinEuro(p) = 0 <=> 
      punishedArt400(p) & Premeditated(p).

  ! p in Person:
    fineMaxEuro(p) = 0 <=> 
      punishedArt400(p) & Premeditated(p).

  ! p in Person:
    imprisonmentMinDays(p) = 1825 <=> 
      punishedArt401(p) & ~Premeditated(p).

  ! p in Person:
    imprisonmentMaxDays(p) = 3650 <=> 
      punishedArt401(p) & ~Premeditated(p).

  ! p in Person:
    fineMinEuro(p) = 0 <=> 
      punishedArt401(p) & ~Premeditated(p).

  ! p in Person:
    fineMaxEuro(p) = 0 <=> 
      punishedArt401(p) & ~Premeditated(p).

  ! p in Person:
    imprisonmentMinDays(p) = 3650 <=> 
      punishedArt401(p) & Premeditated(p).

  ! p in Person:
    imprisonmentMaxDays(p) = 5475 <=> 
      punishedArt401(p) & Premeditated(p).

  ! p in Person:
    fineMinEuro(p) = 0 <=> 
      punishedArt401(p) & Premeditated(p).

  ! p in Person:
    fineMaxEuro(p) = 0 <=> 
      punishedArt401(p) & Premeditated(p).
}
