vocabulary V {
  type Person
  type Estate
  is_surviving_spouse_of: Person * Person -> Bool
  is_estate_of: Estate * Person -> Bool
  leaves_descendants: Person -> Bool
  leaves_adopted_children: Person -> Bool
  leaves_descendants_of_adopted_children: Person -> Bool
  leaves_qualifying_descendant_line: Person -> Bool
  obtains_usufruct_of_entire_estate: Person * Estate -> Bool
}

theory T:V {
  ! deceased in Person: ((leaves_descendants(deceased))) => ((leaves_qualifying_descendant_line(deceased))).
  ! deceased in Person: ((leaves_adopted_children(deceased))) => ((leaves_qualifying_descendant_line(deceased))).
  ! deceased in Person: ((leaves_descendants_of_adopted_children(deceased))) => ((leaves_qualifying_descendant_line(deceased))).
  ! spouse in Person, deceased in Person, estate in Estate: (((is_surviving_spouse_of(spouse,deceased)) & (is_estate_of(estate,deceased)) & (leaves_qualifying_descendant_line(deceased)))) => ((obtains_usufruct_of_entire_estate(spouse,estate))).
}
