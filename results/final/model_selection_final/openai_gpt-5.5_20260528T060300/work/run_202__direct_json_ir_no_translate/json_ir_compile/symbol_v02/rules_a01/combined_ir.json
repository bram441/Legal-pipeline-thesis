{
  "types": [
    "Person",
    "Estate"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The first person is directly stated as the surviving spouse of the second person."
    },
    {
      "name": "is_estate_of",
      "args": [
        "Estate",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The estate is directly stated as belonging to the deceased person."
    },
    {
      "name": "leaves_descendants",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased person leaves descendants."
    },
    {
      "name": "leaves_adopted_children",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased person leaves adopted children."
    },
    {
      "name": "leaves_descendants_of_adopted_children",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased person leaves descendants of adopted children."
    },
    {
      "name": "leaves_qualifying_descendant_line",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The deceased person leaves descendants, adopted children, or descendants of adopted children."
    },
    {
      "name": "obtains_usufruct_of_entire_estate",
      "args": [
        "Person",
        "Estate"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "output_category": "right",
      "description": "The surviving spouse obtains usufruct of the entire estate."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "leaves_descendants",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "leaves_qualifying_descendant_line",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "leaves_adopted_children",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "leaves_qualifying_descendant_line",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "leaves_descendants_of_adopted_children",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "leaves_qualifying_descendant_line",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "estate",
          "type": "Estate"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_estate_of",
              "args": [
                "estate",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_qualifying_descendant_line",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "obtains_usufruct_of_entire_estate",
          "args": [
            "spouse",
            "estate"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}