          "args": [
            "spouse",
            "asset"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
        {
          "pred": "is_surviving_spouse_of",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "deceased_leaves_qualifying_relatives",
          "args": [
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "subject_to_statutory_return_right",
          "args": [
            "asset"
          ],
          "negated": false
        },
        {
          "pred": "contrary_provision_for_statutory_return_asset",
          "args": [
            "asset"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "receives_usufruct_of",
