{
  "types": [
    "Person",
    "Asset"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The first person is directly stated to be the surviving spouse of the second person."
    },
    {
      "name": "deceased_leaves_ascendant_relatives",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deceased person leaves relatives in the ascending line."
    },
    {
      "name": "deceased_leaves_close_collateral_relatives",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deceased person leaves close collateral relatives."
    },
    {
      "name": "deceased_leaves_qualifying_relatives",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The deceased person leaves either ascendant relatives or close collateral relatives."
    },
    {
      "name": "share_in_community_property_of_deceased",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset is the deceased person's share in the community property."
    },
    {
      "name": "share_in_exclusive_spousal_co_owned_property_of_deceased",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset is the deceased person's share in property held undivided exclusively between the spouses."
    },
    {
      "name": "other_asset_of_deceased_own_property",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset is another asset of the deceased person's own property."
    },
    {
      "name": "subject_to_statutory_return_right",
      "args": [
        "Asset"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset is subject to a statutory right of return."
    },
    {
      "name": "contrary_provision_in_gift_deed",
      "args": [
        "Asset"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "A deed of gift provides otherwise for the asset."
    },
    {
      "name": "contrary_provision_in_will",
      "args": [
        "Asset"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "A will provides otherwise for the asset."
    },
    {
      "name": "contrary_provision_for_statutory_return_asset",
      "args": [
        "Asset"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "A deed of gift or will provides otherwise for the statutory return asset."
    },
    {
      "name": "receives_full_ownership_of",
      "args": [
        "Person",
        "Asset"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "output_category": "right",
      "description": "The person receives full ownership of the asset as a legal consequence."
    },
    {
      "name": "receives_usufruct_of",
      "args": [
        "Person",
        "Asset"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "output_category": "right",
      "description": "The person receives usufruct of the asset as a legal consequence."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "deceased_leaves_ascendant_relatives",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "deceased_leaves_qualifying_relatives",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
