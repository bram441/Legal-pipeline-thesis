          "pred": "is_surviving_spouse_of",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "deceased_leaves_qualifying_relatives",
          "args": [
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "share_in_exclusive_spousal_co_owned_property_of_deceased",
          "args": [
            "asset",
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "receives_full_ownership_of",
          "args": [
            "spouse",
            "asset"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
