vocabulary V {
  type Company
  type FinancialYear
  has_legal_personality: Company -> Bool
  last_closed_financial_year: Company * FinancialYear -> Bool
  next_financial_year: FinancialYear * FinancialYear -> Bool
  previous_financial_year: FinancialYear * FinancialYear -> Bool
  employee_criterion_exceeded: Company * FinancialYear -> Bool
  turnover_criterion_exceeded: Company * FinancialYear -> Bool
  balance_sheet_criterion_exceeded: Company * FinancialYear -> Bool
  more_than_one_criterion_exceeded: Company * FinancialYear -> Bool
  no_more_than_one_criterion_exceeded: Company * FinancialYear -> Bool
  more_than_one_criterion_exceeded_for_two_consecutive_years: Company * FinancialYear -> Bool
  no_more_than_one_criterion_exceeded_for_two_consecutive_years: Company * FinancialYear -> Bool
  is_small_company: Company * FinancialYear -> Bool
  loses_small_company_status_from: Company * FinancialYear -> Bool
  gains_small_company_status_from: Company * FinancialYear -> Bool
  annual_average_employees: Company * FinancialYear -> Int
  annual_net_turnover_excluding_vat: Company * FinancialYear -> Real
  balance_sheet_total: Company * FinancialYear -> Real
}

theory T:V {
  ! company in Company, year in FinancialYear: ((annual_average_employees(company,year) > 50)) => ((employee_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: ((annual_net_turnover_excluding_vat(company,year) > 11250000.0)) => ((turnover_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: ((balance_sheet_total(company,year) > 6000000.0)) => ((balance_sheet_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: (((employee_criterion_exceeded(company,year)) & (turnover_criterion_exceeded(company,year)))) => ((more_than_one_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: (((employee_criterion_exceeded(company,year)) & (balance_sheet_criterion_exceeded(company,year)))) => ((more_than_one_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: (((turnover_criterion_exceeded(company,year)) & (balance_sheet_criterion_exceeded(company,year)))) => ((more_than_one_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: ((~more_than_one_criterion_exceeded(company,year))) => ((no_more_than_one_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: ((more_than_one_criterion_exceeded(company,year))) => ((~no_more_than_one_criterion_exceeded(company,year))).
  ! company in Company, second_year in FinancialYear, first_year in FinancialYear: (((more_than_one_criterion_exceeded(company,second_year)) & (more_than_one_criterion_exceeded(company,first_year)) & (previous_financial_year(second_year,first_year)))) => ((more_than_one_criterion_exceeded_for_two_consecutive_years(company,second_year))).
  ! company in Company, second_year in FinancialYear, first_year in FinancialYear: (((no_more_than_one_criterion_exceeded(company,second_year)) & (no_more_than_one_criterion_exceeded(company,first_year)) & (previous_financial_year(second_year,first_year)))) => ((no_more_than_one_criterion_exceeded_for_two_consecutive_years(company,second_year))).
  ! company in Company, year in FinancialYear: (((has_legal_personality(company)) & (last_closed_financial_year(company,year)) & (no_more_than_one_criterion_exceeded(company,year)))) => ((is_small_company(company,year))).
  ! company in Company, year in FinancialYear: (((has_legal_personality(company)) & (last_closed_financial_year(company,year)) & (more_than_one_criterion_exceeded(company,year)))) => ((~is_small_company(company,year))).
  ! company in Company, second_year in FinancialYear, effect_year in FinancialYear: (((has_legal_personality(company)) & (more_than_one_criterion_exceeded_for_two_consecutive_years(company,second_year)) & (next_financial_year(second_year,effect_year)))) => ((loses_small_company_status_from(company,effect_year))).
  ! company in Company, second_year in FinancialYear, effect_year in FinancialYear: (((has_legal_personality(company)) & (no_more_than_one_criterion_exceeded_for_two_consecutive_years(company,second_year)) & (next_financial_year(second_year,effect_year)))) => ((gains_small_company_status_from(company,effect_year))).
}
