vocabulary V {
  type Company
  type FinancialYear
  has_legal_personality: Company -> Bool
  is_last_closed_financial_year: Company * FinancialYear -> Bool
  employee_threshold_exceeded: Company * FinancialYear -> Bool
  net_turnover_threshold_exceeded: Company * FinancialYear -> Bool
  balance_sheet_total_threshold_exceeded: Company * FinancialYear -> Bool
  more_than_one_criterion_exceeded: Company * FinancialYear -> Bool
  at_most_one_criterion_exceeded: Company * FinancialYear -> Bool
  is_small_company: Company * FinancialYear -> Bool
  annual_average_employees: Company * FinancialYear -> Int
  annual_net_turnover_excluding_vat: Company * FinancialYear -> Real
  balance_sheet_total: Company * FinancialYear -> Real
}

theory T:V {
  ! company in Company, year in FinancialYear: ((employee_threshold_exceeded(company,year))) <=> ((annual_average_employees(company,year) > 50)).
  ! company in Company, year in FinancialYear: ((net_turnover_threshold_exceeded(company,year))) <=> ((annual_net_turnover_excluding_vat(company,year) > 11250000.0)).
  ! company in Company, year in FinancialYear: ((balance_sheet_total_threshold_exceeded(company,year))) <=> ((balance_sheet_total(company,year) > 6000000.0)).
  ! company in Company, year in FinancialYear: ((more_than_one_criterion_exceeded(company,year))) <=> ((((employee_threshold_exceeded(company,year)) & (net_turnover_threshold_exceeded(company,year))) | (((employee_threshold_exceeded(company,year)) & (balance_sheet_total_threshold_exceeded(company,year))) | ((net_turnover_threshold_exceeded(company,year)) & (balance_sheet_total_threshold_exceeded(company,year)))))).
  ! company in Company, year in FinancialYear: ((at_most_one_criterion_exceeded(company,year))) <=> ((~more_than_one_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: (((has_legal_personality(company)) & (is_last_closed_financial_year(company,year)) & (~more_than_one_criterion_exceeded(company,year)))) => ((is_small_company(company,year))).
  ! company in Company, year in FinancialYear: (((is_last_closed_financial_year(company,year)) & (more_than_one_criterion_exceeded(company,year)))) => ((~is_small_company(company,year))).
}
