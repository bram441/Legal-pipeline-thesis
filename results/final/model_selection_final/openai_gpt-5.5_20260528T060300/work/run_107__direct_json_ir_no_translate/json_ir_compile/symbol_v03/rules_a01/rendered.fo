vocabulary V {
  type Person
  does_not_provide_proof_of_belgian_nationality: Person -> Bool
  not_union_citizen: Person -> Bool
  not_covered_by_eu_free_movement_law: Person -> Bool
  present_on_territory: Person -> Bool
  does_not_satisfy_entry_or_stay_conditions: Person -> Bool
  subject_to_removal_procedure: Person -> Bool
  subject_to_international_protection_procedure: Person -> Bool
  subject_to_responsible_member_state_determination_or_transfer_procedure: Person -> Bool
  individual_examination_performed: Person -> Bool
  all_case_circumstances_considered: Person -> Bool
  current_and_real_reasons_to_assume_absconding: Person -> Bool
  no_residence_application_after_illegal_entry_or_stay: Person -> Bool
  international_protection_request_late: Person -> Bool
  used_false_or_misleading_information_or_documents: Person -> Bool
  committed_fraud_or_used_unlawful_means: Person -> Bool
  failed_to_cooperate_with_immigration_authorities: Person -> Bool
  declared_unwilling_or_failed_to_comply_with_transfer_refusal_or_removal_measure: Person -> Bool
  declared_unwilling_or_failed_to_comply_with_unsuspended_entry_ban: Person -> Bool
  declared_unwilling_or_failed_to_comply_with_less_coercive_measure: Person -> Bool
  declared_unwilling_or_failed_to_comply_with_public_order_or_national_security_restrictive_measure: Person -> Bool
  declared_unwilling_or_failed_to_comply_with_equivalent_member_state_measure: Person -> Bool
  subject_to_unsuspended_entry_ban: Person -> Bool
  new_application_immediately_after_refusal_end_or_removal_decision: Person -> Bool
  concealed_prior_fingerprints_in_responsible_state: Person -> Bool
  multiple_applications_with_negative_or_no_title_outcome: Person -> Bool
  concealed_prior_international_protection_request_in_responsible_state: Person -> Bool
  came_for_purposes_other_than_application: Person -> Bool
  fined_for_manifestly_unlawful_appeal: Person -> Bool
  has_valid_travel_passport_or_identity_document: Person -> Bool
  recognized_as_national_and_laissez_passer_promised: Person -> Bool
  nationality_category_allows_minister_laissez_passer: Person -> Bool
  subject_to_absconding_relevant_procedure: Person -> Bool
  absconding_objective_criterion_met: Person -> Bool
  is_foreigner: Person -> Bool
  is_third_country_national: Person -> Bool
  is_in_illegal_stay: Person -> Bool
  risk_of_absconding: Person -> Bool
  is_identified_foreigner: Person -> Bool
}

theory T:V {
  ! person in Person: ((does_not_provide_proof_of_belgian_nationality(person))) => ((is_foreigner(person))).
  ! person in Person: ((not_union_citizen(person)) & (not_covered_by_eu_free_movement_law(person))) => ((is_third_country_national(person))).
  ! person in Person: ((is_foreigner(person)) & (present_on_territory(person)) & (does_not_satisfy_entry_or_stay_conditions(person))) => ((is_in_illegal_stay(person))).
  ! person in Person: ((subject_to_removal_procedure(person))) => ((subject_to_absconding_relevant_procedure(person))).
  ! person in Person: ((subject_to_international_protection_procedure(person))) => ((subject_to_absconding_relevant_procedure(person))).
  ! person in Person: ((subject_to_responsible_member_state_determination_or_transfer_procedure(person))) => ((subject_to_absconding_relevant_procedure(person))).
  ! person in Person: ((no_residence_application_after_illegal_entry_or_stay(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((international_protection_request_late(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((used_false_or_misleading_information_or_documents(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((committed_fraud_or_used_unlawful_means(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((failed_to_cooperate_with_immigration_authorities(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((declared_unwilling_or_failed_to_comply_with_transfer_refusal_or_removal_measure(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((declared_unwilling_or_failed_to_comply_with_unsuspended_entry_ban(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((declared_unwilling_or_failed_to_comply_with_less_coercive_measure(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((declared_unwilling_or_failed_to_comply_with_public_order_or_national_security_restrictive_measure(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((declared_unwilling_or_failed_to_comply_with_equivalent_member_state_measure(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((subject_to_unsuspended_entry_ban(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((new_application_immediately_after_refusal_end_or_removal_decision(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((concealed_prior_fingerprints_in_responsible_state(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((multiple_applications_with_negative_or_no_title_outcome(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((concealed_prior_international_protection_request_in_responsible_state(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((came_for_purposes_other_than_application(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((fined_for_manifestly_unlawful_appeal(person))) => ((absconding_objective_criterion_met(person))).
  ! person in Person: ((is_foreigner(person)) & (subject_to_absconding_relevant_procedure(person)) & (current_and_real_reasons_to_assume_absconding(person)) & (individual_examination_performed(person)) & (all_case_circumstances_considered(person)) & (absconding_objective_criterion_met(person))) => ((risk_of_absconding(person))).
  ! person in Person: ((is_foreigner(person)) & (has_valid_travel_passport_or_identity_document(person))) => ((is_identified_foreigner(person))).
  ! person in Person: ((is_foreigner(person)) & (recognized_as_national_and_laissez_passer_promised(person))) => ((is_identified_foreigner(person))).
  ! person in Person: ((is_foreigner(person)) & (nationality_category_allows_minister_laissez_passer(person))) => ((is_identified_foreigner(person))).
}
