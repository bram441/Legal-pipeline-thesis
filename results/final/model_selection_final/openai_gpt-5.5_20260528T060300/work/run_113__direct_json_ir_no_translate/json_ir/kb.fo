vocabulary V {
  type Company
  type FinancialYear
  has_legal_personality: Company -> Bool
  last_closed_financial_year: Company * FinancialYear -> Bool
  employee_threshold_exceeded: Company * FinancialYear -> Bool
  net_turnover_threshold_exceeded: Company * FinancialYear -> Bool
  balance_sheet_total_threshold_exceeded: Company * FinancialYear -> Bool
  more_than_one_criterion_exceeded: Company * FinancialYear -> Bool
  is_small_company: Company * FinancialYear -> Bool
  annual_average_employees: Company * FinancialYear -> Int
  annual_net_turnover_excluding_vat: Company * FinancialYear -> Real
  balance_sheet_total: Company * FinancialYear -> Real
}

theory T:V {
  ! c in Company, fy in FinancialYear: ((annual_average_employees(c,fy) > 50)) => ((employee_threshold_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((annual_net_turnover_excluding_vat(c,fy) > 11250000.0)) => ((net_turnover_threshold_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((balance_sheet_total(c,fy) > 6000000.0)) => ((balance_sheet_total_threshold_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((employee_threshold_exceeded(c,fy)) & (net_turnover_threshold_exceeded(c,fy)))) => ((more_than_one_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((employee_threshold_exceeded(c,fy)) & (balance_sheet_total_threshold_exceeded(c,fy)))) => ((more_than_one_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((net_turnover_threshold_exceeded(c,fy)) & (balance_sheet_total_threshold_exceeded(c,fy)))) => ((more_than_one_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((has_legal_personality(c)) & (last_closed_financial_year(c,fy)) & (~more_than_one_criterion_exceeded(c,fy))) => ((is_small_company(c,fy))).
  ! c in Company, fy in FinancialYear: ((last_closed_financial_year(c,fy)) & (more_than_one_criterion_exceeded(c,fy))) => ((~is_small_company(c,fy))).
}
