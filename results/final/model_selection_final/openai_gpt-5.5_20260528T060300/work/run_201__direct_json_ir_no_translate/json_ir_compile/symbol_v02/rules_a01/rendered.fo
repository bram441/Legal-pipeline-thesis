vocabulary V {
  type Person
  is_surviving_spouse_of: Person * Person -> Bool
  leaves_descendants: Person -> Bool
  leaves_adopted_children: Person -> Bool
  leaves_descendants_of_adopted_children: Person -> Bool
  obtains_usufruct_of_entire_estate: Person * Person -> Bool
}

theory T:V {
  ! spouse in Person, deceased in Person: (((is_surviving_spouse_of(spouse,deceased)) & (leaves_descendants(deceased)))) => ((obtains_usufruct_of_entire_estate(spouse,deceased))).
  ! spouse in Person, deceased in Person: (((is_surviving_spouse_of(spouse,deceased)) & (leaves_adopted_children(deceased)))) => ((obtains_usufruct_of_entire_estate(spouse,deceased))).
  ! spouse in Person, deceased in Person: (((is_surviving_spouse_of(spouse,deceased)) & (leaves_descendants_of_adopted_children(deceased)))) => ((obtains_usufruct_of_entire_estate(spouse,deceased))).
}
