vocabulary V {
  type Company
  type FinancialYear
  has_legal_personality: Company -> Bool
  is_last_closed_financial_year: Company * FinancialYear -> Bool
  employee_threshold_exceeded: Company * FinancialYear -> Bool
  net_turnover_threshold_exceeded: Company * FinancialYear -> Bool
  balance_sheet_total_threshold_exceeded: Company * FinancialYear -> Bool
  more_than_one_criterion_exceeded: Company * FinancialYear -> Bool
  no_more_than_one_criterion_exceeded: Company * FinancialYear -> Bool
  is_small_company: Company * FinancialYear -> Bool
  annual_average_employees: Company * FinancialYear -> Int
  annual_net_turnover_excluding_vat: Company * FinancialYear -> Real
  balance_sheet_total: Company * FinancialYear -> Real
}

theory T:V {
  ! company in Company, year in FinancialYear: ((annual_average_employees(company,year) > 50)) => ((employee_threshold_exceeded(company,year))).
  ! company in Company, year in FinancialYear: ((annual_net_turnover_excluding_vat(company,year) > 11250000.0)) => ((net_turnover_threshold_exceeded(company,year))).
  ! company in Company, year in FinancialYear: ((balance_sheet_total(company,year) > 6000000.0)) => ((balance_sheet_total_threshold_exceeded(company,year))).
  ! company in Company, year in FinancialYear: (((employee_threshold_exceeded(company,year)) & (net_turnover_threshold_exceeded(company,year)))) => ((more_than_one_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: (((employee_threshold_exceeded(company,year)) & (balance_sheet_total_threshold_exceeded(company,year)))) => ((more_than_one_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: (((net_turnover_threshold_exceeded(company,year)) & (balance_sheet_total_threshold_exceeded(company,year)))) => ((more_than_one_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: ((~more_than_one_criterion_exceeded(company,year))) => ((no_more_than_one_criterion_exceeded(company,year))).
  ! company in Company, year in FinancialYear: (((has_legal_personality(company)) & (is_last_closed_financial_year(company,year)) & (no_more_than_one_criterion_exceeded(company,year)))) => ((is_small_company(company,year))).
  ! company in Company, year in FinancialYear: (((has_legal_personality(company)) & (is_last_closed_financial_year(company,year)) & (more_than_one_criterion_exceeded(company,year)))) => ((~is_small_company(company,year))).
}
