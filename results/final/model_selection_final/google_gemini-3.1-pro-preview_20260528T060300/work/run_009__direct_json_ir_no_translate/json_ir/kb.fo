vocabulary V {
  type Company
  type FinancialYear
  has_legal_personality: Company -> Bool
  is_last_closed_financial_year: FinancialYear * Company -> Bool
  employee_threshold_exceeded: Company * FinancialYear -> Bool
  turnover_threshold_exceeded: Company * FinancialYear -> Bool
  balance_sheet_threshold_exceeded: Company * FinancialYear -> Bool
  more_than_one_criterion_exceeded: Company * FinancialYear -> Bool
  is_small_company: Company -> Bool
  annual_average_employees: Company * FinancialYear -> Real
  annual_net_turnover: Company * FinancialYear -> Real
  balance_sheet_total: Company * FinancialYear -> Real
}

theory T:V {
  ! c in Company, y in FinancialYear: ((annual_average_employees(c,y) > 50.0)) => ((employee_threshold_exceeded(c,y))).
  ! c in Company, y in FinancialYear: ((annual_net_turnover(c,y) > 11250000.0)) => ((turnover_threshold_exceeded(c,y))).
  ! c in Company, y in FinancialYear: ((balance_sheet_total(c,y) > 6000000.0)) => ((balance_sheet_threshold_exceeded(c,y))).
  ! c in Company, y in FinancialYear: (((employee_threshold_exceeded(c,y)) & (turnover_threshold_exceeded(c,y)))) => ((more_than_one_criterion_exceeded(c,y))).
  ! c in Company, y in FinancialYear: (((employee_threshold_exceeded(c,y)) & (balance_sheet_threshold_exceeded(c,y)))) => ((more_than_one_criterion_exceeded(c,y))).
  ! c in Company, y in FinancialYear: (((turnover_threshold_exceeded(c,y)) & (balance_sheet_threshold_exceeded(c,y)))) => ((more_than_one_criterion_exceeded(c,y))).
  ! c in Company, y in FinancialYear: (((has_legal_personality(c)) & (is_last_closed_financial_year(y,c)) & (~more_than_one_criterion_exceeded(c,y)))) => ((is_small_company(c))).
  ! c in Company, y in FinancialYear: (((is_last_closed_financial_year(y,c)) & (more_than_one_criterion_exceeded(c,y)))) => ((~is_small_company(c))).
}
