vocabulary V {
  type Person
  type Property
  is_surviving_spouse_of: Person * Person -> Bool
  is_heir_of: Person * Person -> Bool
  served_as_principal_residence_of_family_at_opening_of_succession: Property * Person -> Bool
  acquires_right_to_rent: Person * Property -> Bool
  is_excluded_from_right_to_rent: Person * Property -> Bool
}

theory T:V {
  ! spouse in Person, deceased in Person, property in Property: (((is_surviving_spouse_of(spouse,deceased)) & (served_as_principal_residence_of_family_at_opening_of_succession(property,deceased)))) => ((acquires_right_to_rent(spouse,property))).
  ! heir in Person, deceased in Person, property in Property: (((is_heir_of(heir,deceased)) & (~is_surviving_spouse_of(heir,deceased)) & (served_as_principal_residence_of_family_at_opening_of_succession(property,deceased)))) => ((is_excluded_from_right_to_rent(heir,property))).
}
