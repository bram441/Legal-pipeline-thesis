{
  "types": [
    "Person"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The first person is the surviving spouse of the second person."
    },
    {
      "name": "leaves_descendants",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person leaves descendants."
    },
    {
      "name": "leaves_adopted_children",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person leaves adopted children."
    },
    {
      "name": "leaves_descendants_of_adopted_children",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person leaves descendants of adopted children."
    },
    {
      "name": "leaves_qualifying_offspring",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The person leaves descendants, adopted children, or descendants of adopted children."
    },
    {
      "name": "acquires_usufruct_of_entire_estate",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "description": "The first person acquires the usufruct of the entire estate of the second person."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "leaves_descendants",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "leaves_qualifying_offspring",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "leaves_adopted_children",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "leaves_qualifying_offspring",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "leaves_descendants_of_adopted_children",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "leaves_qualifying_offspring",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_qualifying_offspring",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct_of_entire_estate",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}