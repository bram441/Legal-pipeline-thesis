    {
      "name": "deed_or_will_specifies_otherwise",
      "args": [
        "Property"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deed of donation or will specifies otherwise regarding the property."
    },
    {
      "name": "leaves_descendants_or_adopted_children_or_their_descendants",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The deceased person leaves descendants, adopted children, or descendants of adopted children."
