        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_ascendants_or_close_collaterals",
              "args": [
                "deceased"
