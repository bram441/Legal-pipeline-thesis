              "negated": false
            },
            {
              "pred": "is_asset_subject_to_legal_return",
              "args": [
                "asset"
              ],
              "negated": false
            },
            {
              "pred": "provided_otherwise_for_legal_return",
              "args": [
                "asset"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct",
          "args": [
