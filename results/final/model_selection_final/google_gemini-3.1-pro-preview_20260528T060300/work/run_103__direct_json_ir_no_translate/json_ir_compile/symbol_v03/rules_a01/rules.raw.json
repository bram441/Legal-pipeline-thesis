{
  "rules": [
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "estate",
          "type": "Estate"
        }
      ],
      "if": [
        {
          "pred": "is_surviving_spouse_of",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "is_estate_of",
          "args": [
            "estate",
            "deceased"
          ],
          "negated": false
        },
        {
          "or": [
            {
              "pred": "leaves_other_heirs",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_no_heirs",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_full_ownership_of",
          "args": [
            "spouse",
            "estate"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}