{
  "types": [
    "Person",
    "Asset"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving spouse of the second person (the deceased).",
      "directly_observable": true
    },
    {
      "name": "leaves_ascendants_or_close_collaterals",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased person leaves ascendants or close collaterals."
    },
    {
      "name": "is_share_in_common_or_exclusive_undivided_estate",
      "args": [
        "Asset",
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is the share of the deceased (second argument) in the common estate or in the estate exclusively in undivided co-ownership with the surviving spouse (third argument).",
      "directly_observable": true
    },
    {
      "name": "is_other_asset_of_own_estate",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is among the other assets of the deceased person's own estate.",
      "directly_observable": true
    },
    {
      "name": "is_subject_to_legal_return",
      "args": [
        "Asset"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is subject to the right of legal return referred to in article 4.24 or 4.25.",
      "directly_observable": true
    },
    {
      "name": "otherwise_provided_in_donation_or_will",
      "args": [
        "Asset"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "It is otherwise provided in the deed of donation or in the will regarding the asset."
    },
    {
      "name": "acquires_full_ownership",
      "args": [
        "Person",
        "Asset"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person acquires full ownership of the asset.",
      "legal_output": true
    },
    {
      "name": "acquires_usufruct",
      "args": [
        "Person",
        "Asset"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person acquires the usufruct of the asset.",
      "legal_output": true
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_ascendants_or_close_collaterals",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_share_in_common_or_exclusive_undivided_estate",
              "args": [
                "asset",
                "deceased",
                "spouse"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_full_ownership",
          "args": [
            "spouse",
            "asset"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_ascendants_or_close_collaterals",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_other_asset_of_own_estate",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct",
          "args": [
            "spouse",
            "asset"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_ascendants_or_close_collaterals",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_subject_to_legal_return",
