        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover excluding VAT of the company in the financial year."
    },
    {
      "name": "balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
