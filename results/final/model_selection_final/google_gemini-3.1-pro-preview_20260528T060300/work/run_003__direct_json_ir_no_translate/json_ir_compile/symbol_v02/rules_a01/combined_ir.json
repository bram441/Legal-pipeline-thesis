  "rules": [
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "annual_average_employees",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 10
          }
        }
      ],
      "then": [
        {
          "pred": "employee_threshold_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
