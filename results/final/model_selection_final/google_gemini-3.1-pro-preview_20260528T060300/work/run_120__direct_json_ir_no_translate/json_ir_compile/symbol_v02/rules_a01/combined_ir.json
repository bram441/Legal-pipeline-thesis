      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company has legal personality."
    },
    {
      "name": "employee_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the employee threshold in the financial year."
    },
    {
      "name": "turnover_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
