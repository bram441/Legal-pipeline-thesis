        {
          "compare": {
            "left": {
              "func": "annual_net_turnover_excluding_vat",
              "args": [
                "c",
                "y"
              ]
            },
            "op": ">",
            "right": 11250000.0
          }
        }
      ],
      "then": [
        {
          "pred": "turnover_threshold_exceeded",
          "args": [
            "c",
            "y"
          ],
