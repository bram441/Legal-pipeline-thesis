    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "no_application_criterion_met",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "or": [
                {
                  "pred": "false_information_criterion_met",
                  "args": [
                    "p"
                  ],
                  "negated": false
                },
                {
                  "or": [
                    {
                      "pred": "non_cooperation_criterion_met",
                      "args": [
                        "p"
                      ],
                      "negated": false
                    },
                    {
                      "or": [
                        {
                          "pred": "non_compliance_criterion_met",
