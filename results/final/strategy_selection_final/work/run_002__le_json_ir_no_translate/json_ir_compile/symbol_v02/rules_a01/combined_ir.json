    {
      "name": "subject_to_entry_ban_in_other_member_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner is subject to an entry ban in another member state that has neither been lifted nor suspended."
