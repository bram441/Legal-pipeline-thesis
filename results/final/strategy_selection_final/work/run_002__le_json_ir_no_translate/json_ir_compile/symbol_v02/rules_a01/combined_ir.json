                                                {
                                                  "pred": "manifestly_unfounded_appeal_criterion_met",
                                                  "args": [
                                                    "p"
                                                  ],
                                                  "negated": false
                                                }
                                              ]
                                            }
                                          ]
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "at_least_one_absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_foreigner",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "and": [
                {
                  "pred": "reasons_to_assume_will_abscond",
                  "args": [
                    "p"
                  ],
                  "negated": false
                },
                {
                  "and": [
                    {
                      "pred": "subject_to_qualifying_procedure",
                      "args": [
                        "p"
                      ],
                      "negated": false
                    },
                    {
                      "and": [
