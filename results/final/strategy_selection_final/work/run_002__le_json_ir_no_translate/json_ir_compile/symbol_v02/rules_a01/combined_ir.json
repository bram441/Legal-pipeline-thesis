    {
      "name": "non_cooperation_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The non-cooperation criterion is met: the foreigner does not cooperate or has not cooperated with authorities responsible for access, residence, establishment, and removal."
