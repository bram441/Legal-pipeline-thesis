{
  "types": [
    "Person",
    "Document",
    "MemberState"
  ],
  "predicates": [
    {
      "name": "holds_belgian_nationality",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person holds Belgian nationality (directly stated as a background fact in the case)."
    },
    {
      "name": "is_foreigner",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is a foreigner because they do not provide proof of Belgian nationality."
    },
    {
      "name": "is_union_citizen",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
