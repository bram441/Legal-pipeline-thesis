    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "did_not_submit_residence_application_after_illegal_entry_or_during_illegal_residence",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "did_not_submit_international_protection_request_in_time",
              "args": [
                "p"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "no_application_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
