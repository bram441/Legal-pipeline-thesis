    {
      "name": "does_not_cooperate_with_authorities",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner does not cooperate or has not cooperated with the relevant authorities."
