                                  "args": [
                                    "p"
                                  ],
                                  "negated": false
                                },
                                {
                                  "or": [
                                    {
                                      "pred": "concealed_fingerprints_criterion_met",
                                      "args": [
                                        "p"
                                      ],
                                      "negated": false
                                    },
                                    {
                                      "or": [
                                        {
                                          "pred": "multiple_applications_criterion_met",
                                          "args": [
                                            "p"
                                          ],
                                          "negated": false
                                        },
                                        {
                                          "or": [
                                            {
                                              "pred": "concealed_prior_application_criterion_met",
                                              "args": [
                                                "p"
