      "name": "came_for_other_purposes",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner declared or it appears from the file that they came to the Kingdom for purposes other than those for which they submitted a request for international protection or a residence application."
