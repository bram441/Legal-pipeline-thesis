          "pred": "last_closed_financial_year",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        },
        {
          "left": {
            "func": "annual_net_turnover_excl_vat",
            "args": [
              "c",
              "y"
            ]
          },
          "op": ">",
          "right": 900000
        }
      ],
      "then": [
        {
          "pred": "turnover_threshold_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
