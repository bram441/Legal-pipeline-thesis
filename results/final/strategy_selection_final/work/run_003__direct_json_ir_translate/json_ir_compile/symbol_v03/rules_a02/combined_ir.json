{
  "types": [
    "Company",
    "FinancialYear"
  ],
  "predicates": [
    {
      "name": "has_legal_personality",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company has legal personality."
    },
    {
      "name": "is_small_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company qualifies as a small company in the given financial year."
    },
    {
      "name": "is_subsidiary",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company is a subsidiary of another company."
    },
    {
      "name": "is_parent_company",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company is a parent company of another company."
    },
    {
      "name": "employee_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual average employee threshold of 10 in the financial year."
    },
    {
      "name": "turnover_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual net turnover threshold of 900,000 euros (excluding VAT) in the financial year."
    },
    {
      "name": "balance_sheet_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the balance sheet total threshold of 450,000 euros in the financial year."
    },
    {
      "name": "more_than_one_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds more than one of the three micro-company size criteria in the financial year."
    },
    {
      "name": "previous_financial_year",
      "args": [
        "FinancialYear",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The second financial year argument is the financial year immediately preceding the first."
    },
    {
      "name": "next_financial_year",
      "args": [
        "FinancialYear",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The second financial year argument is the financial year immediately following the first."
    },
    {
      "name": "last_closed_financial_year",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The given financial year is the last closed financial year for the company, establishing which year's balance sheet date is used for the micro-company criteria check."
    },
    {
      "name": "is_micro_company",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "derived",
      "output_category": "classification",
      "description": "The company qualifies as a micro-company as defined in Art. 1:25, assessed on the basis of the last closed financial year."
    }
  ],
  "functions": [
    {
      "name": "annual_average_employees",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Int",
      "kind": "observable",
      "description": "The annual average number of employees of the company in the financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover excluding VAT of the company in the financial year, in euros."
    },
    {
      "name": "balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The balance sheet total of the company in the financial year, in euros."
    }
  ],
  "rules": [
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "pred": "last_closed_financial_year",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        },
        {
          "left": {
            "func": "annual_average_employees",
            "args": [
              "c",
              "y"
            ]
          },
          "op": ">",
          "right": 10
        }
      ],
      "then": [
        {
          "pred": "employee_threshold_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
