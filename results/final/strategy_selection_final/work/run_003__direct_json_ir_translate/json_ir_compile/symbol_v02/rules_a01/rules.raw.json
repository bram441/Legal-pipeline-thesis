          ]
        }
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {
          "and": [
            {"pred": "is_small_company", "args": ["c", "fy"], "negated": false},
