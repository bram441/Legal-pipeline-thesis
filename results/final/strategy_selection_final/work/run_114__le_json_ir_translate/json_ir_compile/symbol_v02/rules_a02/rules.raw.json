{
  "rules": [
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "y"], "negated": false},
        {"left": {"func": "annual_average_employees", "args": ["c", "y"]}, "op": ">", "right": 50}
      ],
      "then": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "y"], "negated": false},
        {"left": {"func": "annual_net_turnover_excl_vat", "args": ["c", "y"]}, "op": ">", "right": 11250000}
      ],
      "then": [
        {"pred": "turnover_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "y"], "negated": false},
        {"left": {"func": "balance_sheet_total", "args": ["c", "y"]}, "op": ">", "right": 6000000}
      ],
      "then": [
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "y"], "negated": false},
        {"pred": "turnover_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "then": [
        {"pred": "more_than_one_small_company_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "y"], "negated": false},
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "then": [
        {"pred": "more_than_one_small_company_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "turnover_criterion_exceeded", "args": ["c", "y"], "negated": false},
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "then": [
        {"pred": "more_than_one_small_company_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "has_legal_personality", "args": ["c"], "negated": false},
        {"pred": "is_last_closed_financial_year", "args": ["c", "y"], "negated": false},
        {"pred": "more_than_one_small_company_criterion_exceeded", "args": ["c", "y"], "negated": true}
      ],
      "then": [
        {"pred": "is_small_company", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "y"], "negated": false},
        {"pred": "more_than_one_small_company_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "then": [
        {"pred": "is_small_company", "args": ["c", "y"], "negated": true}
      ],
      "operator": "implies"
    }
  ]
}