vocabulary V {
  type Person
  type Document
  type MemberState
  type Procedure
  is_alien: Person -> Bool
  is_union_citizen: Person -> Bool
  has_community_free_movement_right: Person -> Bool
  is_third_country_national: Person -> Bool
  meets_entry_or_stay_conditions: Person -> Bool
  is_in_illegal_stay: Person -> Bool
  is_subject_of_removal_procedure: Person -> Bool
  is_subject_of_international_protection_procedure: Person -> Bool
  is_subject_of_responsible_member_state_procedure: Person -> Bool
  individual_examination_performed: Person -> Bool
  has_valid_travel_document: Person -> Bool
  recognised_as_national_by_own_country: Person -> Bool
  falls_within_laissez_passer_nationality_category: Person -> Bool
  is_identified_alien: Person -> Bool
  no_residence_application_after_illegal_entry_or_stay: Person -> Bool
  used_false_information_or_documents: Person -> Bool
  does_not_cooperate_with_authorities: Person -> Bool
  declared_unwillingness_or_failed_to_comply_with_measure: Person -> Bool
  subject_to_unlifted_entry_ban: Person -> Bool
  submitted_new_application_immediately_after_negative_decision: Person -> Bool
  concealed_fingerprints_in_other_state: Person -> Bool
  submitted_multiple_applications_with_negative_outcome: Person -> Bool
  concealed_prior_international_protection_application: Person -> Bool
  declared_or_apparent_purpose_other_than_application: Person -> Bool
  subject_to_fine_for_manifestly_unlawful_appeal: Person -> Bool
  absconding_risk_criterion_met: Person -> Bool
  risk_of_absconding: Person -> Bool
}

theory T:V {
  ! p in Person: (((is_alien(p)) & (~is_union_citizen(p)) & (~has_community_free_movement_right(p)))) => ((is_third_country_national(p))).
  ! p in Person: (((is_alien(p)) & (~meets_entry_or_stay_conditions(p)))) => ((is_in_illegal_stay(p))).
  ! p in Person: (((is_alien(p)) & (has_valid_travel_document(p)))) => ((is_identified_alien(p))).
  ! p in Person: (((is_alien(p)) & (recognised_as_national_by_own_country(p)))) => ((is_identified_alien(p))).
  ! p in Person: (((is_alien(p)) & (falls_within_laissez_passer_nationality_category(p)))) => ((is_identified_alien(p))).
  ! p in Person: ((no_residence_application_after_illegal_entry_or_stay(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((used_false_information_or_documents(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((does_not_cooperate_with_authorities(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((declared_unwillingness_or_failed_to_comply_with_measure(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((subject_to_unlifted_entry_ban(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((submitted_new_application_immediately_after_negative_decision(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((concealed_fingerprints_in_other_state(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((submitted_multiple_applications_with_negative_outcome(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((concealed_prior_international_protection_application(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((declared_or_apparent_purpose_other_than_application(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: ((subject_to_fine_for_manifestly_unlawful_appeal(p))) => ((absconding_risk_criterion_met(p))).
  ! p in Person: (((is_alien(p)) & ((is_subject_of_removal_procedure(p)) | (is_subject_of_international_protection_procedure(p)) | (is_subject_of_responsible_member_state_procedure(p))) & (individual_examination_performed(p)) & (absconding_risk_criterion_met(p)))) => ((risk_of_absconding(p))).
}
