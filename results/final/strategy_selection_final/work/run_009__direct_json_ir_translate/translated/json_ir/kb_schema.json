          "negated": false
        },
        {
          "pred": "more_than_one_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "is_small_company",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "pred": "more_than_one_criterion_exceeded",
          "args": [
