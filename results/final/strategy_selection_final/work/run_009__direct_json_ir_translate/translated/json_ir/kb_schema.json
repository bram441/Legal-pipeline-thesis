{
  "types": [
    "Company",
    "FinancialYear"
  ],
  "predicates": [
    {
      "name": "has_legal_personality",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The company has legal personality (a background status directly assertable from case facts).",
      "directly_observable": true
    },
    {
      "name": "employee_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual average employee threshold of 50 in the financial year."
    },
    {
      "name": "turnover_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual net turnover threshold of 11,250,000 euros (exclusive of VAT) in the financial year."
    },
    {
      "name": "balance_sheet_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the balance sheet total threshold of 6,000,000 euros in the financial year."
    },
    {
      "name": "more_than_one_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds more than one of the three listed criteria in the financial year."
    },
    {
      "name": "is_small_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The company qualifies as a small company under par. 1 in the given financial year.",
      "legal_output": true,
      "output_category": "classification"
    }
  ],
  "functions": [
    {
      "name": "annual_average_employees",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Int",
      "kind": "observable",
      "description": "The annual average number of employees of the company in the financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover of the company exclusive of value added tax in the financial year, in euros."
    },
    {
      "name": "balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The balance sheet total of the company in the financial year, in euros."
    }
  ],
  "rules": [
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "annual_average_employees",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 50
          }
        }
      ],
      "then": [
        {
          "pred": "employee_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "annual_net_turnover_excl_vat",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 11250000.0
          }
        }
      ],
      "then": [
        {
          "pred": "turnover_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "balance_sheet_total",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 6000000.0
          }
        }
      ],
      "then": [
        {
          "pred": "balance_sheet_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "employee_criterion_exceeded",
              "args": [
                "c",
                "fy"
              ],
              "negated": false
            },
            {
              "pred": "turnover_criterion_exceeded",
              "args": [
                "c",
                "fy"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "more_than_one_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "employee_criterion_exceeded",
              "args": [
                "c",
                "fy"
              ],
              "negated": false
            },
            {
              "pred": "balance_sheet_criterion_exceeded",
              "args": [
                "c",
                "fy"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "more_than_one_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "turnover_criterion_exceeded",
              "args": [
                "c",
                "fy"
              ],
              "negated": false
            },
            {
              "pred": "balance_sheet_criterion_exceeded",
              "args": [
                "c",
                "fy"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "more_than_one_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
