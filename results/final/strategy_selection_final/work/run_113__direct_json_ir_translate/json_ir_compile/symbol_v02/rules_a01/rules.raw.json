{
  "rules": [
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"compare": {"left": {"func": "annual_average_employees", "args": ["c", "fy"]}, "op": ">", "right": 50}}
      ],
      "then": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"compare": {"left": {"func": "annual_net_turnover_excl_vat", "args": ["c", "fy"]}, "op": ">", "right": 11250000.0}}
      ],
      "then": [
        {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
