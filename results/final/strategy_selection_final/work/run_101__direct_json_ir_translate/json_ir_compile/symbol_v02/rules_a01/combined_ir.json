{
  "types": [
    "Person",
    "Asset"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The first person is the surviving spouse of the second person (the deceased)."
    },
    {
      "name": "is_deceased",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is deceased."
    },
    {
      "name": "leaves_descendants",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deceased person leaves descendants."
    },
    {
      "name": "leaves_adopted_children",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deceased person leaves adopted children."
    },
    {
      "name": "leaves_descendants_of_adopted_children",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deceased person leaves descendants of adopted children."
    },
    {
      "name": "qualifies_as_estate_of",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset forms part of the entire estate of the deceased person."
    },
    {
      "name": "qualifying_heirs_exist",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The deceased leaves descendants, adopted children, or descendants of adopted children."
    },
    {
      "name": "acquires_usufruct_of_estate",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The first person (surviving spouse) acquires the usufruct of the entire estate of the second person (the deceased).",
      "legal_output": true,
      "output_category": "right"
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "leaves_descendants",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_adopted_children",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_descendants_of_adopted_children",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "qualifying_heirs_exist",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_deceased",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "qualifying_heirs_exist",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct_of_estate",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}