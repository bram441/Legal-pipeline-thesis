          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deceased_leaves_ascendants_or_close_collaterals",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "asset_is_own_property_of_deceased",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "asset_subject_to_legal_reversion",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": true
            }
          ]
        }
