{
  "types": [
    "Person",
    "Asset"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The first person is the surviving spouse of the second (deceased) person."
    },
    {
      "name": "deceased_leaves_ascendants",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deceased person leaves relatives in the ascending line."
    },
    {
      "name": "deceased_leaves_close_collaterals",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deceased person leaves close collateral relatives."
    },
    {
      "name": "asset_is_common_property",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset forms part of the common matrimonial property of the deceased person."
    },
    {
      "name": "asset_is_exclusive_undivided_between_spouses",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset is exclusively held in undivided co-ownership between the spouses of the deceased."
    },
    {
      "name": "asset_is_own_property_of_deceased",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset belongs to the own (separate) estate of the deceased person."
    },
    {
      "name": "asset_subject_to_legal_reversion_art424",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset is subject to the right of legal reversion as referred to in article 4.24 for the deceased person."
    },
    {
      "name": "asset_subject_to_legal_reversion_art425",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The asset is subject to the right of legal reversion as referred to in article 4.25 for the deceased person."
    },
    {
      "name": "deed_of_gift_excludes_usufruct",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deed of gift for the asset stipulates otherwise than the default usufruct for the surviving spouse of the deceased."
    },
    {
      "name": "testament_excludes_usufruct",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The testament stipulates otherwise than the default usufruct on the reversion asset for the surviving spouse of the deceased."
    },
    {
      "name": "deceased_leaves_ascendants_or_close_collaterals",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The deceased leaves relatives in the ascending line or close collateral relatives."
    },
    {
      "name": "asset_is_common_or_exclusive_undivided",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The asset is part of the common matrimonial property or exclusively undivided between the spouses of the deceased."
    },
    {
      "name": "asset_subject_to_legal_reversion",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The asset is subject to the right of legal reversion under article 4.24 or 4.25 for the deceased."
    },
    {
      "name": "reversion_usufruct_excluded_by_instrument",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The deed of gift or testament stipulates otherwise than the default usufruct on the reversion asset for the surviving spouse."
    },
    {
      "name": "acquires_full_ownership_of_asset",
      "args": [
        "Person",
        "Asset"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "output_category": "legal_effect",
      "description": "The surviving spouse acquires full ownership of the asset as a legal consequence of succession."
    },
    {
      "name": "acquires_usufruct_of_asset",
      "args": [
        "Person",
        "Asset"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "output_category": "legal_effect",
      "description": "The surviving spouse acquires usufruct over the asset as a legal consequence of succession."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "deceased_leaves_ascendants",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deceased_leaves_close_collaterals",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "deceased_leaves_ascendants_or_close_collaterals",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "asset",
          "type": "Asset"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "asset_is_common_property",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "asset_is_exclusive_undivided_between_spouses",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "asset_is_common_or_exclusive_undivided",
          "args": [
            "asset",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "asset",
          "type": "Asset"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "asset_subject_to_legal_reversion_art424",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "asset_subject_to_legal_reversion_art425",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "asset_subject_to_legal_reversion",
          "args": [
            "asset",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "asset",
          "type": "Asset"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "deed_of_gift_excludes_usufruct",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "testament_excludes_usufruct",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "reversion_usufruct_excluded_by_instrument",
          "args": [
            "asset",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deceased_leaves_ascendants_or_close_collaterals",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "asset_is_common_or_exclusive_undivided",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_full_ownership_of_asset",
          "args": [
            "spouse",
