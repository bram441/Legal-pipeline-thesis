{
  "rules": [
    {
      "forall": [
        {"var": "spouse", "type": "Person"},
        {"var": "deceased", "type": "Person"},
        {"var": "estate", "type": "Estate"}
      ],
      "if": [
        {
          "and": [
            {"pred": "is_surviving_spouse_of", "args": ["spouse", "deceased"], "negated": false},
            {"pred": "deceased_leaves_heirs_other_than_surviving_spouse", "args": ["deceased"], "negated": false},
            {"pred": "is_estate_of", "args": ["estate", "deceased"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "acquires_full_ownership_of_entire_estate", "args": ["spouse", "estate"], "negated": false}
      ],
      "operator": "implies"
    },
    {
