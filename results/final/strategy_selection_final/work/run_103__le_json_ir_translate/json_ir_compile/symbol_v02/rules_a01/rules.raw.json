            {"pred": "is_estate_of", "args": ["estate", "deceased"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "acquires_full_ownership_of_entire_estate", "args": ["spouse", "estate"], "negated": false}
      ],
