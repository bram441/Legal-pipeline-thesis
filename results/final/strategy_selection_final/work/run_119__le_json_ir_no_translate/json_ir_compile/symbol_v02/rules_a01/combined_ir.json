        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company has legal personality (a background/prerequisite status directly assertable from case facts)."
    },
    {
      "name": "is_starting_company",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company is starting its business (first financial year)."
