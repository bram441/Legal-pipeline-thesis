{
  "types": [
    "Person",
    "ImmovableProperty"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving spouse of the second (deceased) person.",
      "directly_observable": true
    },
    {
      "name": "served_as_family_principal_residence",
      "args": [
        "ImmovableProperty",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The immovable property served as the family's principal residence at the time the estate of the deceased person opened.",
      "directly_observable": true
    },
    {
      "name": "is_subject_to_lease",
      "args": [
        "ImmovableProperty"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The immovable property is subject to a lease.",
      "directly_observable": true
    },
    {
      "name": "is_heir_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is an heir of the second (deceased) person.",
      "directly_observable": true
    },
    {
      "name": "acquires_right_to_lease",
      "args": [
        "Person",
        "ImmovableProperty"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires the right to the lease of the immovable property to the exclusion of all other heirs.",
      "legal_output": true
    },
    {
      "name": "excluded_from_lease_right",
      "args": [
        "Person",
        "ImmovableProperty"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person (heir) is excluded from the right to the lease of the immovable property in favour of the surviving spouse."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "property",
          "type": "ImmovableProperty"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "served_as_family_principal_residence",
              "args": [
                "property",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_subject_to_lease",
              "args": [
                "property"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_right_to_lease",
          "args": [
            "spouse",
            "property"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "heir",
          "type": "Person"
        },
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "property",
          "type": "ImmovableProperty"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_heir_of",
              "args": [
                "heir",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "acquires_right_to_lease",
              "args": [
                "spouse",
                "property"
              ],
              "negated": false
            },
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "heir",
                "deceased"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "excluded_from_lease_right",
          "args": [
            "heir",
            "property"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}