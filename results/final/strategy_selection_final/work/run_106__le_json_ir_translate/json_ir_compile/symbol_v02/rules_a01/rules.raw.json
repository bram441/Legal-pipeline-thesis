{
  "rules": [
    {
      "forall": [
        {"var": "spouse", "type": "Person"},
        {"var": "deceased", "type": "Person"},
        {"var": "property", "type": "ImmovableProperty"}
      ],
      "if": [
        {
          "and": [
            {"pred": "is_surviving_spouse_of", "args": ["spouse", "deceased"], "negated": false},
            {"pred": "served_as_family_principal_residence", "args": ["property", "deceased"], "negated": false},
            {"pred": "is_subject_to_lease", "args": ["property"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "acquires_right_to_lease", "args": ["spouse", "property"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "heir", "type": "Person"},
        {"var": "spouse", "type": "Person"},
        {"var": "deceased", "type": "Person"},
        {"var": "property", "type": "ImmovableProperty"}
      ],
      "if": [
        {
          "and": [
            {"pred": "is_heir_of", "args": ["heir", "deceased"], "negated": false},
            {"pred": "is_surviving_spouse_of", "args": ["spouse", "deceased"], "negated": false},
            {"pred": "acquires_right_to_lease", "args": ["spouse", "property"], "negated": false},
            {"pred": "is_surviving_spouse_of", "args": ["heir", "deceased"], "negated": true}
          ]
        }
      ],
      "then": [
        {"pred": "excluded_from_lease_right", "args": ["heir", "property"], "negated": false}
      ],
      "operator": "implies"
    }
  ]
}