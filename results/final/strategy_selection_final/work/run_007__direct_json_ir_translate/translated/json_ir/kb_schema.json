    {
      "name": "is_surviving_legally_cohabiting_partner_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving legally cohabiting partner of the second person (the deceased).",
      "directly_observable": true
    },
    {
      "name": "is_heir_called_to_estate_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
