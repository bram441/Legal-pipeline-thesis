      "args": [
        "Property",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property served as the family's principal residence at the time the estate of the deceased opened.",
      "directly_observable": true
    },
    {
      "name": "is_household_effects_of",
      "args": [
        "Property",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property consists of household effects present in the family principal residence of the deceased at the time the estate opened.",
      "directly_observable": true
    },
    {
      "name": "subject_to_legal_reversion_right",
      "args": [
        "Property"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property is subject to a right of legal reversion as referred to in article 4.24 or article 4.25.",
