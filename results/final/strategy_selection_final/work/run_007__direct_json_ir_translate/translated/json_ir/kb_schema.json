      "name": "acquires_usufruct_of",
      "args": [
        "Person",
        "Property"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving legally cohabiting partner acquires the usufruct of the property as a legal consequence of the law.",
      "legal_output": true
    }
  ],
