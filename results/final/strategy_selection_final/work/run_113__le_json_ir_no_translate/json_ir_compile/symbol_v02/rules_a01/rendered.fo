vocabulary V {
  type Company
  type FinancialYear
  is_legal_entity: Company -> Bool
  employee_criterion_exceeded: Company * FinancialYear -> Bool
  turnover_criterion_exceeded: Company * FinancialYear -> Bool
  balance_sheet_criterion_exceeded: Company * FinancialYear -> Bool
  more_than_one_small_company_criterion_exceeded: Company * FinancialYear -> Bool
  not_more_than_one_small_company_criterion_exceeded: Company * FinancialYear -> Bool
  is_most_recently_closed_financial_year: FinancialYear * Company -> Bool
  is_small_company: Company -> Bool
  annual_average_employees: Company * FinancialYear -> Int
  annual_net_turnover_excl_vat: Company * FinancialYear -> Real
  balance_sheet_total: Company * FinancialYear -> Real
}

theory T:V {
  ! c in Company, fy in FinancialYear: ((annual_average_employees(c,fy) > 50)) => ((employee_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((annual_net_turnover_excl_vat(c,fy) > 11250000.0)) => ((turnover_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((balance_sheet_total(c,fy) > 6000000.0)) => ((balance_sheet_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((employee_criterion_exceeded(c,fy)) & (turnover_criterion_exceeded(c,fy)))) => ((more_than_one_small_company_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((employee_criterion_exceeded(c,fy)) & (balance_sheet_criterion_exceeded(c,fy)))) => ((more_than_one_small_company_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((turnover_criterion_exceeded(c,fy)) & (balance_sheet_criterion_exceeded(c,fy)))) => ((more_than_one_small_company_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((~more_than_one_small_company_criterion_exceeded(c,fy))) => ((not_more_than_one_small_company_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((is_legal_entity(c)) & (is_most_recently_closed_financial_year(fy,c)) & (not_more_than_one_small_company_criterion_exceeded(c,fy)))) => ((is_small_company(c))).
  ! c in Company, fy in FinancialYear: (((is_most_recently_closed_financial_year(fy,c)) & (more_than_one_small_company_criterion_exceeded(c,fy)))) => ((~is_small_company(c))).
}
