      "args": [
        "FinancialYear",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first financial year is the immediately preceding financial year of the second financial year.",
      "directly_observable": true
    },
    {
      "name": "is_last_closed_financial_year",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The given financial year is the last closed financial year for the company.",
      "directly_observable": true
    },
    {
      "name": "employee_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual average employee threshold of 10 in the financial year."
    },
    {
      "name": "turnover_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual net turnover threshold of 900,000 euros (excluding VAT) in the financial year."
    },
    {
      "name": "balance_sheet_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the balance sheet total threshold of 450,000 euros in the financial year."
    },
    {
      "name": "more_than_one_micro_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds more than one of the three micro-company criteria (employees, turnover, balance sheet) in the financial year. Defined as at least two of the three threshold predicates holding simultaneously."
    },
    {
      "name": "is_micro_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The company qualifies as a micro-company in the given financial year under the statutory definition.",
      "legal_output": true,
      "output_category": "classification"
    }
  ],
  "functions": [
    {
      "name": "annual_average_employees",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Int",
      "kind": "observable",
      "description": "The annual average number of employees of the company in the financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover of the company excluding value added tax in the financial year, in euros."
    },
    {
      "name": "balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The balance sheet total of the company in the financial year, in euros."
    }
  ],
  "rules": [
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "annual_average_employees",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 10
          }
        }
      ],
      "then": [
        {
          "pred": "employee_threshold_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
