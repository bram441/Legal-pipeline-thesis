{
  "types": [
    "Person",
    "Document",
    "MemberState",
    "Procedure"
  ],
  "predicates": [
    {
      "name": "is_foreigner",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person cannot prove Belgian nationality and is therefore a foreigner under the law."
    },
    {
      "name": "has_belgian_nationality",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person can prove they hold Belgian nationality. Directly assertable as a background fact in case texts.",
      "directly_observable": true
    },
    {
      "name": "is_eu_citizen",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is a citizen of the European Union.",
      "directly_observable": true
    },
    {
      "name": "falls_under_eu_free_movement_law",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person falls under EU law on free movement as defined in the Schengen Borders Code.",
      "directly_observable": true
    },
    {
      "name": "is_third_country_national",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is a third-country national: not an EU citizen and not covered by EU free movement law."
    },
    {
      "name": "meets_entry_or_residence_conditions",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person meets or continues to meet the legal conditions for entry to or residence on the territory.",
      "directly_observable": true
    },
    {
      "name": "in_illegal_residence",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is present on the territory without meeting the conditions for entry or residence (illegal residence)."
    },
    {
      "name": "subject_to_removal_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is subject to a removal procedure.",
      "directly_observable": true
    },
    {
      "name": "subject_to_international_protection_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is subject to a procedure for granting international protection.",
      "directly_observable": true
    },
    {
      "name": "subject_to_responsibility_determination_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is subject to a procedure to determine or transfer to the responsible member state for an international protection request.",
      "directly_observable": true
    },
    {
      "name": "individual_examination_performed",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "An individual examination has been performed for the person regarding risk of absconding.",
      "directly_observable": true
    },
    {
      "name": "risk_of_absconding",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "There is a current and real risk that the person will abscond, established after individual examination on the basis of objective criteria.",
      "legal_output": true
    },
    {
      "name": "no_residence_application_filed_after_illegal_entry_or_stay",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person did not file a residence application after illegal entry or during illegal stay, or did not submit an international protection request within the legally prescribed period.",
      "directly_observable": true
    },
    {
      "name": "used_false_or_misleading_information_or_documents",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person used false or misleading information, false or forged documents, committed fraud, or used other unlawful means in a protection, residence, removal, or pushback procedure.",
      "directly_observable": true
    },
    {
      "name": "fails_to_cooperate_with_authorities",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person does not cooperate or has not cooperated with authorities responsible for enforcement of regulations on entry, residence, establishment, and removal.",
      "directly_observable": true
    },
    {
      "name": "indicated_unwillingness_to_comply_with_measure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person has indicated unwillingness to comply with, or has already failed to comply with, a transfer, pushback, removal, entry ban, liberty-restricting, or equivalent measure.",
      "directly_observable": true
    },
    {
      "name": "subject_to_active_entry_ban",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is subject to an entry ban in Belgium or another member state that has not been lifted or suspended.",
      "directly_observable": true
    },
    {
      "name": "filed_new_application_immediately_after_negative_decision",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person filed a new residence application or international protection request immediately after a refusal of entry or residence, end of stay, pushback, or removal measure.",
      "directly_observable": true
    },
    {
      "name": "concealed_prior_fingerprints_in_other_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "When questioned, the person concealed that they had previously given fingerprints in another state bound by EU rules on determining the state responsible for an international protection request.",
      "directly_observable": true
    },
    {
      "name": "multiple_applications_with_negative_outcomes",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person has submitted multiple international protection requests and/or residence applications in Belgium or other member states that resulted in negative decisions or did not lead to a residence permit.",
      "directly_observable": true
    },
    {
      "name": "concealed_prior_international_protection_request",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "When questioned, the person concealed that they had previously submitted an international protection request in another state bound by EU rules on determining the responsible state.",
      "directly_observable": true
    },
    {
      "name": "entered_for_purposes_other_than_stated_application",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person declared or their file shows they came to Belgium for purposes other than those for which they submitted an international protection request or residence application.",
      "directly_observable": true
    },
    {
      "name": "fined_for_manifestly_unfounded_appeal",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person has been fined for submitting a manifestly unfounded appeal to the Council for Alien Law Litigation.",
      "directly_observable": true
    },
    {
      "name": "holds_valid_travel_document",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person holds a valid travel document, valid passport, or valid identity document.",
      "directly_observable": true
    },
    {
      "name": "recognised_as_national_by_home_country",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person has been recognised as a national by the national authority of their country, which declared willingness to issue a laissez-passer.",
      "directly_observable": true
    },
    {
      "name": "nationality_eligible_for_ministerial_laissez_passer",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person falls under a nationality category for which the minister can issue a laissez-passer directly.",
      "directly_observable": true
    },
    {
      "name": "is_identified_foreigner",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person qualifies as an identified foreigner under the law: holds a valid travel/identity document, is recognised by their home country, or falls under a ministerial laissez-passer nationality category."
    },
    {
      "name": "absconding_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "At least one of the objective criteria for risk of absconding is met for the person."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "has_belgian_nationality",
          "args": [
            "p"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_eu_citizen",
          "args": [
            "p"
          ],
          "negated": true
        },
        {
          "pred": "falls_under_eu_free_movement_law",
          "args": [
            "p"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "is_third_country_national",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "pred": "meets_entry_or_residence_conditions",
          "args": [
            "p"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "in_illegal_residence",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "holds_valid_travel_document",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "recognised_as_national_by_home_country",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "nationality_eligible_for_ministerial_laissez_passer",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "no_residence_application_filed_after_illegal_entry_or_stay",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "used_false_or_misleading_information_or_documents",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "fails_to_cooperate_with_authorities",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "indicated_unwillingness_to_comply_with_measure",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "subject_to_active_entry_ban",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "filed_new_application_immediately_after_negative_decision",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "concealed_prior_fingerprints_in_other_state",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "multiple_applications_with_negative_outcomes",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "concealed_prior_international_protection_request",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "entered_for_purposes_other_than_stated_application",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "fined_for_manifestly_unfounded_appeal",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "individual_examination_performed",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "or": [
            {
              "pred": "subject_to_removal_procedure",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "subject_to_international_protection_procedure",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "subject_to_responsibility_determination_procedure",
              "args": [
                "p"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "risk_of_absconding",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}