vocabulary V {
  type Person
  is_surviving_legally_cohabiting_partner_of: Person * Person -> Bool
  is_descendant_of: Person * Person -> Bool
  exception_applies_surviving_partner_is_descendant: Person * Person -> Bool
}

theory T:V {
  ! survivor in Person, predeceased in Person: (((is_surviving_legally_cohabiting_partner_of(survivor,predeceased)) & (is_descendant_of(survivor,predeceased)))) => ((exception_applies_surviving_partner_is_descendant(survivor,predeceased))).
}
