{
  "types": [
    "Person",
    "Property"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving spouse of the second person (the deceased). This background status may be directly asserted in a case.",
      "directly_observable": true
    },
    {
      "name": "is_heir_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is an heir of the second person (the deceased).",
      "directly_observable": true
    },
    {
      "name": "served_as_family_principal_residence",
      "args": [
        "Property",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property served as the family's principal residence at the time the estate of the deceased opened.",
      "directly_observable": true
    },
    {
      "name": "is_leased_property",
      "args": [
        "Property"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property is held under a lease (i.e. the deceased held a lease on the property).",
      "directly_observable": true
    },
    {
      "name": "acquires_right_to_lease",
      "args": [
        "Person",
        "Property"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires exclusively the right to the lease of the property, to the exclusion of all other heirs.",
      "legal_output": true
    },
    {
      "name": "excluded_from_right_to_lease",
      "args": [
        "Person",
        "Property"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The heir is excluded from the right to the lease of the property because the surviving spouse acquires it exclusively."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "prop",
          "type": "Property"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "served_as_family_principal_residence",
              "args": [
                "prop",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_leased_property",
              "args": [
                "prop"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_right_to_lease",
          "args": [
            "spouse",
            "prop"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "heir",
          "type": "Person"
        },
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "prop",
          "type": "Property"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_heir_of",
              "args": [
                "heir",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "acquires_right_to_lease",
              "args": [
                "spouse",
                "prop"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "excluded_from_right_to_lease",
          "args": [
            "heir",
            "prop"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}