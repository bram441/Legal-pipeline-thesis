{
  "rules": [
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"compare": {"left": {"func": "annual_average_employees", "args": ["c"]}, "op": ">", "right": 10}}
      ],
      "then": [
        {"pred": "employee_criterion_exceeded", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"compare": {"left": {"func": "annual_net_turnover_excl_vat", "args": ["c"]}, "op": ">", "right": 900000.0}}
      ],
      "then": [
        {"pred": "turnover_criterion_exceeded", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"compare": {"left": {"func": "balance_sheet_total", "args": ["c"]}, "op": ">", "right": 450000.0}}
      ],
      "then": [
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"and": [
          {"pred": "employee_criterion_exceeded", "args": ["c"], "negated": false},
          {"pred": "turnover_criterion_exceeded", "args": ["c"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_micro_criterion_exceeded", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"and": [
          {"pred": "employee_criterion_exceeded", "args": ["c"], "negated": false},
          {"pred": "balance_sheet_criterion_exceeded", "args": ["c"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_micro_criterion_exceeded", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"and": [
          {"pred": "turnover_criterion_exceeded", "args": ["c"], "negated": false},
          {"pred": "balance_sheet_criterion_exceeded", "args": ["c"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_micro_criterion_exceeded", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"pred": "more_than_one_micro_criterion_exceeded", "args": ["c"], "negated": true}
      ],
      "then": [
        {"pred": "not_more_than_one_micro_criterion_exceeded", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"and": [
          {"pred": "is_small_company_with_legal_personality", "args": ["c"], "negated": false},
          {"pred": "is_subsidiary_company", "args": ["c"], "negated": true},
          {"pred": "is_parent_company", "args": ["c"], "negated": true},
          {"pred": "not_more_than_one_micro_criterion_exceeded", "args": ["c"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "is_micro_company", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"pred": "more_than_one_micro_criterion_exceeded", "args": ["c"], "negated": false}
      ],
      "then": [
        {"pred": "is_micro_company", "args": ["c"], "negated": true}
      ],
      "operator": "implies"
    }
  ]
}