{
  "types": [
    "Person",
    "MemberState",
    "Authority"
  ],
  "predicates": [
    {
      "name": "holds_belgian_nationality",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person provides proof that they hold Belgian nationality."
    },
    {
      "name": "is_foreigner",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is a foreigner because they do not provide proof of Belgian nationality."
    },
    {
      "name": "is_citizen_of_union",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is a citizen of the European Union."
    },
    {
      "name": "falls_under_community_free_movement_law",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person falls under Community law on free movement as defined in Article 2, point 5, of the Schengen Borders Code."
    },
    {
      "name": "is_third_country_national",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is a national of a third country: not a Union citizen and not covered by Community free movement law."
    },
    {
      "name": "present_on_territory",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is present on the territory."
    },
    {
      "name": "meets_access_conditions",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person satisfies the conditions for access to the territory as determined by applicable law."
    },
    {
      "name": "meets_residence_conditions",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person satisfies the conditions for residence on the territory as determined by applicable law."
    },
    {
      "name": "satisfies_access_or_residence_conditions",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The person satisfies the conditions for access to or residence on the territory: meets access conditions or meets residence conditions."
    },
    {
      "name": "is_in_illegal_residence",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is in illegal residence: present on the territory without satisfying access or residence conditions."
    },
    {
      "name": "has_valid_travel_document",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is in possession of a valid travel document."
    },
    {
      "name": "has_valid_passport",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is in possession of a valid passport."
    },
    {
      "name": "has_valid_identity_document",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is in possession of a valid identity document."
    },
    {
      "name": "recognised_as_national_by_own_authority",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person has been recognised as a national by the national authority of their country."
    },
    {
      "name": "own_authority_willing_to_issue_laissez_passer",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The national authority of the person's country has declared itself willing to issue a laissez-passer."
    },
    {
      "name": "falls_under_nationality_category_for_direct_laissez_passer",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person falls under a category of nationalities for which the minister may issue a laissez-passer directly."
    },
    {
      "name": "is_identified_foreigner",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is an identified foreigner based on one of the legally defined identification grounds."
    },
    {
      "name": "subject_to_removal_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner is subject to a removal procedure."
    },
    {
      "name": "subject_to_international_protection_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner is subject to a procedure for granting international protection."
    },
    {
      "name": "subject_to_responsible_member_state_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner is subject to a procedure for determining or transferring to the member state responsible for examining the application for international protection."
    },
    {
      "name": "individual_examination_performed",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "An individual examination has been performed taking into account all circumstances specific to the case."
    },
    {
      "name": "objective_criteria_indicate_absconding",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "One or more objective criteria established in paragraph 2 give reasons to believe the foreigner will abscond."
    },
    {
      "name": "risk_of_absconding_is_current_and_real",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The risk of absconding is current and real."
    },
    {
      "name": "risk_of_absconding",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "description": "A risk of absconding exists for the foreigner based on the legally defined conditions."
    },
    {
      "name": "did_not_submit_residence_application_after_illegal_entry_or_during_illegal_residence",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner did not submit a residence application after illegal entry or during illegal residence."
    },
    {
      "name": "did_not_submit_international_protection_request_in_time",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner did not submit a request for international protection within the period provided by the law."
    },
    {
      "name": "no_application_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The no-application criterion is met: the foreigner did not submit a residence application after illegal entry or during illegal residence, or did not submit a request for international protection within the legal period."
    },
    {
      "name": "used_false_or_misleading_information",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner used false or misleading information in the context of a relevant procedure."
    },
    {
      "name": "used_false_or_falsified_documents",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner used false or falsified documents in the context of a relevant procedure."
    },
    {
      "name": "committed_fraud",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner committed fraud in the context of a relevant procedure."
    },
    {
      "name": "used_other_unlawful_means",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner used other unlawful means in the context of a relevant procedure."
    },
    {
      "name": "false_information_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The false-information criterion is met: the foreigner used false or misleading information, false documents, committed fraud, or used other unlawful means in a relevant procedure."
    },
    {
      "name": "does_not_cooperate_with_authorities",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner does not cooperate or has not cooperated with the authorities responsible for access, residence, establishment, and removal regulations."
    },
    {
      "name": "non_cooperation_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The non-cooperation criterion is met: the foreigner does not cooperate with the relevant authorities."
    },
    {
      "name": "indicated_unwillingness_to_comply_with_transfer_refoulement_removal",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner has indicated unwillingness to comply with or has already failed to comply with a transfer, refoulement, or removal measure."
    },
    {
      "name": "indicated_unwillingness_to_comply_with_entry_ban",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner has indicated unwillingness to comply with or has already failed to comply with an entry ban that has neither been lifted nor suspended."
    },
    {
      "name": "indicated_unwillingness_to_comply_with_less_coercive_measure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner has indicated unwillingness to comply with or has already failed to comply with a less coercive measure aimed at guaranteeing transfer, refoulement, or removal."
    },
    {
      "name": "indicated_unwillingness_to_comply_with_freedom_restricting_measure_for_public_order",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner has indicated unwillingness to comply with or has already failed to comply with a freedom-restricting measure aimed at guaranteeing public order or national security."
    },
    {
      "name": "indicated_unwillingness_to_comply_with_equivalent_measure_by_other_member_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner has indicated unwillingness to comply with or has already failed to comply with an equivalent measure taken by another member state."
    },
    {
      "name": "non_compliance_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The non-compliance criterion is met based on one or more of the legally defined non-compliance grounds."
    },
    {
      "name": "subject_to_entry_ban_in_kingdom",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner is subject to an entry ban in the Kingdom that has neither been lifted nor suspended."
    },
    {
      "name": "subject_to_entry_ban_in_other_member_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner is subject to an entry ban in another member state that has neither been lifted nor suspended."
    },
    {
      "name": "entry_ban_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The entry-ban criterion is met: the foreigner is subject to an active entry ban in the Kingdom and/or another member state."
    },
    {
      "name": "submitted_new_application_after_negative_decision",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner submitted a new residence application or new request for international protection immediately after a decision refusing entry or residence, ending residence, or a refoulement or removal measure."
    },
    {
      "name": "new_application_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The new-application criterion is met: the foreigner submitted a new application immediately after a negative decision."
    },
    {
      "name": "concealed_fingerprints_in_other_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner, while being questioned on that point, concealed that they had already provided fingerprints in another state bound by the European regulations on determining the state responsible for examining a request for international protection."
    },
    {
      "name": "concealed_fingerprints_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The concealed-fingerprints criterion is met: the foreigner concealed prior fingerprint provision in another bound state."
    },
    {
      "name": "submitted_multiple_applications_with_negative_outcome",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner has submitted multiple requests for international protection and/or residence applications in the Kingdom or in one or more other member states that have resulted in a negative decision or have not led to the issuance of a residence permit."
    },
    {
      "name": "multiple_applications_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The multiple-applications criterion is met: the foreigner submitted multiple applications with negative outcomes."
    },
    {
      "name": "concealed_prior_application_in_other_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner, while being questioned on that point, concealed that they had previously submitted a request for international protection in another state bound by the European regulations on determining the state responsible."
    },
    {
      "name": "concealed_prior_application_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The concealed-prior-application criterion is met: the foreigner concealed a prior application in another bound state."
    },
    {
      "name": "came_for_other_purposes_than_stated_in_application",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner has declared or it appears from their file that they came to the Kingdom for purposes other than those for which they submitted a request for international protection or a residence application."
    },
    {
      "name": "other_purposes_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The other-purposes criterion is met: the foreigner came for purposes other than those stated in their application."
    },
    {
      "name": "subject_to_fine_for_manifestly_unlawful_appeal",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The foreigner is subject to a fine because they submitted a manifestly unlawful appeal to the Council for Alien Law Litigation."
    },
    {
      "name": "manifestly_unfounded_appeal_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The manifestly-unfounded-appeal criterion is met: the foreigner is subject to a fine for a manifestly unlawful appeal."
    },
    {
      "name": "at_least_one_absconding_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "At least one of the objective absconding criteria defined in paragraph 2 is met for the foreigner."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "holds_belgian_nationality",
          "args": [
            "p"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_citizen_of_union",
              "args": [
                "p"
              ],
              "negated": true
            },
            {
              "pred": "falls_under_community_free_movement_law",
              "args": [
                "p"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "is_third_country_national",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "meets_access_conditions",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "satisfies_access_or_residence_conditions",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "meets_residence_conditions",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "satisfies_access_or_residence_conditions",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "present_on_territory",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "satisfies_access_or_residence_conditions",
              "args": [
                "p"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "is_in_illegal_residence",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "has_valid_travel_document",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "has_valid_passport",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "has_valid_identity_document",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "recognised_as_national_by_own_authority",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "own_authority_willing_to_issue_laissez_passer",
              "args": [
                "p"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "falls_under_nationality_category_for_direct_laissez_passer",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "subject_to_removal_procedure",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "subject_to_international_protection_procedure",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "subject_to_responsible_member_state_procedure",
              "args": [
                "p"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "at_least_one_absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "no_application_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "at_least_one_absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
