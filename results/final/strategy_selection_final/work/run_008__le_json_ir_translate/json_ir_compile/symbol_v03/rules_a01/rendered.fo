vocabulary V {
  type Person
  type Procedure
  type MemberState
  type Measure
  provides_proof_of_belgian_nationality: Person -> Bool
  is_alien: Person -> Bool
  is_union_citizen: Person -> Bool
  enjoys_community_right_of_free_movement: Person -> Bool
  is_third_country_national: Person -> Bool
  is_present_on_territory: Person -> Bool
  meets_conditions_for_entry_or_stay: Person -> Bool
  stay_is_illegal: Person -> Bool
  is_subject_of_removal_procedure: Person -> Bool
  is_subject_of_international_protection_procedure: Person -> Bool
  is_subject_of_dublin_transfer_procedure: Person -> Bool
  reasons_to_believe_will_abscond: Person -> Bool
  individual_examination_performed: Person -> Bool
  risk_is_current_and_real: Person -> Bool
  subject_to_qualifying_procedure: Person -> Bool
  at_least_one_objective_criterion_met: Person -> Bool
  risk_of_absconding: Person -> Bool
  possesses_valid_travel_document: Person -> Bool
  recognised_as_national_by_own_authority: Person -> Bool
  national_authority_willing_to_issue_laissez_passer: Person -> Bool
  falls_within_nationality_category_for_ministerial_laissez_passer: Person -> Bool
  is_identified_alien: Person -> Bool
  criterion_1_met: Person -> Bool
  no_residence_application_after_illegal_entry_or_stay: Person -> Bool
  no_international_protection_application_within_time_limit: Person -> Bool
  criterion_2_met: Person -> Bool
  used_false_or_misleading_information: Person -> Bool
  used_false_or_falsified_documents: Person -> Bool
  committed_fraud_in_procedure: Person -> Bool
  used_other_unlawful_means: Person -> Bool
  criterion_3_met: Person -> Bool
  does_not_cooperate_with_authorities: Person -> Bool
  criterion_4_met: Person -> Bool
  declared_unwillingness_to_comply_with_measure: Person -> Bool
  failed_to_comply_with_measure: Person -> Bool
  criterion_5_met: Person -> Bool
  subject_to_active_entry_ban_in_kingdom: Person -> Bool
  subject_to_active_entry_ban_in_other_member_state: Person -> Bool
  criterion_6_met: Person -> Bool
  submitted_new_application_after_negative_decision: Person -> Bool
  criterion_7_met: Person -> Bool
  concealed_prior_fingerprints_in_other_state: Person -> Bool
  criterion_8_met: Person -> Bool
  submitted_multiple_applications_with_negative_outcome: Person -> Bool
  criterion_9_met: Person -> Bool
  concealed_prior_protection_application_in_other_state: Person -> Bool
  criterion_10_met: Person -> Bool
  came_for_purposes_other_than_application: Person -> Bool
  criterion_11_met: Person -> Bool
  subject_to_fine_for_manifestly_unlawful_appeal: Person -> Bool
}

theory T:V {
  ! p in Person: ((~provides_proof_of_belgian_nationality(p))) => ((is_alien(p))).
  ! p in Person: (((~is_union_citizen(p)) & (~enjoys_community_right_of_free_movement(p)))) => ((is_third_country_national(p))).
  ! p in Person: (((is_present_on_territory(p)) & (~meets_conditions_for_entry_or_stay(p)))) => ((stay_is_illegal(p))).
  ! p in Person: (((is_subject_of_removal_procedure(p)) | (is_subject_of_international_protection_procedure(p)) | (is_subject_of_dublin_transfer_procedure(p)))) => ((subject_to_qualifying_procedure(p))).
  ! p in Person: (((reasons_to_believe_will_abscond(p)) & (subject_to_qualifying_procedure(p)) & (individual_examination_performed(p)) & (risk_is_current_and_real(p)) & (at_least_one_objective_criterion_met(p)))) => ((risk_of_absconding(p))).
  ! p in Person: ((possesses_valid_travel_document(p))) => ((is_identified_alien(p))).
  ! p in Person: (((recognised_as_national_by_own_authority(p)) & (national_authority_willing_to_issue_laissez_passer(p)))) => ((is_identified_alien(p))).
  ! p in Person: ((falls_within_nationality_category_for_ministerial_laissez_passer(p))) => ((is_identified_alien(p))).
  ! p in Person: ((no_residence_application_after_illegal_entry_or_stay(p))) => ((criterion_1_met(p))).
  ! p in Person: ((no_international_protection_application_within_time_limit(p))) => ((criterion_1_met(p))).
  ! p in Person: ((used_false_or_misleading_information(p))) => ((criterion_2_met(p))).
  ! p in Person: ((used_false_or_falsified_documents(p))) => ((criterion_2_met(p))).
  ! p in Person: ((committed_fraud_in_procedure(p))) => ((criterion_2_met(p))).
  ! p in Person: ((used_other_unlawful_means(p))) => ((criterion_2_met(p))).
  ! p in Person: ((does_not_cooperate_with_authorities(p))) => ((criterion_3_met(p))).
  ! p in Person: ((declared_unwillingness_to_comply_with_measure(p))) => ((criterion_4_met(p))).
  ! p in Person: ((failed_to_comply_with_measure(p))) => ((criterion_4_met(p))).
  ! p in Person: ((subject_to_active_entry_ban_in_kingdom(p))) => ((criterion_5_met(p))).
  ! p in Person: ((subject_to_active_entry_ban_in_other_member_state(p))) => ((criterion_5_met(p))).
  ! p in Person: ((submitted_new_application_after_negative_decision(p))) => ((criterion_6_met(p))).
  ! p in Person: ((concealed_prior_fingerprints_in_other_state(p))) => ((criterion_7_met(p))).
  ! p in Person: ((submitted_multiple_applications_with_negative_outcome(p))) => ((criterion_8_met(p))).
  ! p in Person: ((concealed_prior_protection_application_in_other_state(p))) => ((criterion_9_met(p))).
  ! p in Person: ((came_for_purposes_other_than_application(p))) => ((criterion_10_met(p))).
  ! p in Person: ((subject_to_fine_for_manifestly_unlawful_appeal(p))) => ((criterion_11_met(p))).
  ! p in Person: (((criterion_1_met(p)) | (criterion_2_met(p)) | (criterion_3_met(p)) | (criterion_4_met(p)) | (criterion_5_met(p)) | (criterion_6_met(p)) | (criterion_7_met(p)) | (criterion_8_met(p)) | (criterion_9_met(p)) | (criterion_10_met(p)) | (criterion_11_met(p)))) => ((at_least_one_objective_criterion_met(p))).
}
