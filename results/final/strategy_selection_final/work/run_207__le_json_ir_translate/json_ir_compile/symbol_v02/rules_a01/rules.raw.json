{
  "rules": [
    {
      "forall": [
        {"var": "spouse", "type": "Person"},
        {"var": "deceased", "type": "Person"},
        {"var": "property", "type": "ImmovableProperty"},
        {"var": "lease", "type": "Lease"}
      ],
      "if": [
        {
          "and": [
            {"pred": "is_surviving_spouse_of", "args": ["spouse", "deceased"], "negated": false},
            {"pred": "is_deceased", "args": ["deceased"], "negated": false},
            {"pred": "served_as_family_principal_residence_at_estate_opening", "args": ["property", "deceased"], "negated": false},
            {"pred": "property_subject_to_lease", "args": ["property", "lease"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "acquires_right_to_lease", "args": ["spouse", "lease"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "heir", "type": "Person"},
        {"var": "deceased", "type": "Person"},
        {"var": "spouse", "type": "Person"},
        {"var": "property", "type": "ImmovableProperty"},
        {"var": "lease", "type": "Lease"}
      ],
      "if": [
        {
          "and": [
            {"pred": "is_heir_of", "args": ["heir", "deceased"], "negated": false},
            {"pred": "is_surviving_spouse_of", "args": ["spouse", "deceased"], "negated": false},
            {"pred": "is_surviving_spouse_of", "args": ["heir", "deceased"], "negated": true},
            {"pred": "served_as_family_principal_residence_at_estate_opening", "args": ["property", "deceased"], "negated": false},
            {"pred": "property_subject_to_lease", "args": ["property", "lease"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "excluded_from_lease_right", "args": ["heir", "lease"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "heir", "type": "Person"},
        {"var": "lease", "type": "Lease"}
      ],
      "if": [
        {"pred": "excluded_from_lease_right", "args": ["heir", "lease"], "negated": false}
      ],
      "then": [
        {"pred": "acquires_right_to_lease", "args": ["heir", "lease"], "negated": true}
      ],
      "operator": "implies"
    }
  ]
}