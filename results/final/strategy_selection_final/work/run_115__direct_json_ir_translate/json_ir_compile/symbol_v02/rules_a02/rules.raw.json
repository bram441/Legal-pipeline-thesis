{
  "rules": [
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "fy"], "negated": false},
        {"compare": {"left": {"func": "annual_average_employees", "args": ["c", "fy"]}, "op": ">", "right": 10}}
      ],
      "then": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "fy"], "negated": false},
        {"compare": {"left": {"func": "annual_net_turnover_excl_vat", "args": ["c", "fy"]}, "op": ">", "right": 900000}}
      ],
      "then": [
        {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "fy"], "negated": false},
        {"compare": {"left": {"func": "balance_sheet_total", "args": ["c", "fy"]}, "op": ">", "right": 450000}}
      ],
      "then": [
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "fy"], "negated": false},
        {"or": [
          {"and": [
            {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false},
            {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false}
          ]},
          {"and": [
            {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false},
            {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "fy"], "negated": false}
          ]},
          {"and": [
            {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false},
            {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "fy"], "negated": false}
          ]}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_micro_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "fy"], "negated": false},
        {"pred": "more_than_one_micro_criterion_exceeded", "args": ["c", "fy"], "negated": true}
      ],
      "then": [
        {"pred": "micro_criteria_satisfied", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"pred": "has_legal_personality", "args": ["c"], "negated": false},
        {"pred": "is_small_company", "args": ["c"], "negated": false},
        {"pred": "is_subsidiary", "args": ["c"], "negated": true},
        {"pred": "is_parent_company", "args": ["c"], "negated": true},
        {"pred": "micro_criteria_satisfied", "args": ["c"], "negated": false}
      ],
      "then": [
        {"pred": "is_micro_company", "args": ["c"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"pred": "is_subsidiary", "args": ["c"], "negated": false}
      ],
      "then": [
        {"pred": "is_micro_company", "args": ["c"], "negated": true}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}],
      "if": [
        {"pred": "is_parent_company", "args": ["c"], "negated": false}
      ],
      "then": [
        {"pred": "is_micro_company", "args": ["c"], "negated": true}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_last_closed_financial_year", "args": ["c", "fy"], "negated": false},
        {"pred": "more_than_one_micro_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "then": [
        {"pred": "is_micro_company", "args": ["c"], "negated": true}
      ],
      "operator": "implies"
    }
  ]
}