      "kind": "observable",
      "description": "The annual average number of employees of the company in the given financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover exclusive of value added tax of the company in the given financial year, in euros."
