vocabulary V {
  type Person
  type Document
  type MemberState
  type Procedure
  provides_proof_of_belgian_nationality: Person -> Bool
  is_alien: Person -> Bool
  is_union_citizen: Person -> Bool
  enjoys_community_right_of_free_movement: Person -> Bool
  is_third_country_national: Person -> Bool
  meets_entry_or_stay_conditions: Person -> Bool
  is_in_illegal_stay: Person -> Bool
  is_subject_to_removal_procedure: Person -> Bool
  is_subject_to_international_protection_procedure: Person -> Bool
  is_subject_to_responsible_member_state_determination_procedure: Person -> Bool
  individual_examination_performed: Person -> Bool
  risk_of_absconding_is_current_and_real: Person -> Bool
  risk_of_absconding: Person -> Bool
  holds_valid_travel_document: Person -> Bool
  recognised_as_national_by_country_authority: Person -> Bool
  falls_within_laissez_passer_nationality_category: Person -> Bool
  is_identified_alien: Person -> Bool
  criterion_no_residence_application_after_illegal_entry_or_stay: Person -> Bool
  criterion_false_information_or_documents: Person -> Bool
  criterion_non_cooperation_with_authorities: Person -> Bool
  criterion_declared_or_failed_to_comply_with_measure: Person -> Bool
  criterion_subject_to_unlifted_entry_ban: Person -> Bool
  criterion_new_application_after_negative_decision: Person -> Bool
  criterion_concealed_fingerprints_in_other_state: Person -> Bool
  criterion_multiple_applications_with_negative_outcome: Person -> Bool
  criterion_concealed_prior_international_protection_application: Person -> Bool
  criterion_declared_purpose_inconsistent_with_application: Person -> Bool
  criterion_fined_for_manifestly_unlawful_appeal: Person -> Bool
  at_least_one_absconding_criterion_met: Person -> Bool
}

theory T:V {
  ! p in Person: ((~provides_proof_of_belgian_nationality(p))) => ((is_alien(p))).
  ! p in Person: (((~is_union_citizen(p)) & (~enjoys_community_right_of_free_movement(p)))) => ((is_third_country_national(p))).
  ! p in Person: (((is_alien(p)) & (~meets_entry_or_stay_conditions(p)))) => ((is_in_illegal_stay(p))).
  ! p in Person: (((is_alien(p)) & (holds_valid_travel_document(p)))) => ((is_identified_alien(p))).
  ! p in Person: (((is_alien(p)) & (recognised_as_national_by_country_authority(p)))) => ((is_identified_alien(p))).
  ! p in Person: (((is_alien(p)) & (falls_within_laissez_passer_nationality_category(p)))) => ((is_identified_alien(p))).
  ! p in Person: ((criterion_no_residence_application_after_illegal_entry_or_stay(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_false_information_or_documents(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_non_cooperation_with_authorities(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_declared_or_failed_to_comply_with_measure(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_subject_to_unlifted_entry_ban(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_new_application_after_negative_decision(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_concealed_fingerprints_in_other_state(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_multiple_applications_with_negative_outcome(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_concealed_prior_international_protection_application(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_declared_purpose_inconsistent_with_application(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_fined_for_manifestly_unlawful_appeal(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: (((at_least_one_absconding_criterion_met(p)) & (risk_of_absconding_is_current_and_real(p)))) => ((risk_of_absconding_is_current_and_real(p))).
  ! p in Person: (((is_alien(p)) & ((is_subject_to_removal_procedure(p)) | (is_subject_to_international_protection_procedure(p)) | (is_subject_to_responsible_member_state_determination_procedure(p))) & (individual_examination_performed(p)) & (at_least_one_absconding_criterion_met(p)) & (risk_of_absconding_is_current_and_real(p)))) => ((risk_of_absconding(p))).
}
