{
  "rules": [
    {
      "forall": [
        {"var": "deceased", "type": "Person"},
        {"var": "issue", "type": "Person"}
      ],
      "if": [
        {
          "or": [
            {"pred": "is_descendant_of", "args": ["issue", "deceased"], "negated": false},
            {"pred": "is_adopted_child_of", "args": ["issue", "deceased"], "negated": false},
            {"pred": "is_descendant_of_adopted_child_of", "args": ["issue", "deceased"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "deceased_leaves_qualifying_issue", "args": ["deceased"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "spouse", "type": "Person"},
        {"var": "deceased", "type": "Person"}
      ],
      "if": [
        {
          "and": [
            {"pred": "is_surviving_spouse_of", "args": ["spouse", "deceased"], "negated": false},
            {"pred": "is_deceased", "args": ["deceased"], "negated": false},
            {"pred": "deceased_leaves_qualifying_issue", "args": ["deceased"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "acquires_usufruct_of_entire_estate", "args": ["spouse", "deceased"], "negated": false}
      ],
      "operator": "implies"
    }
  ]
}