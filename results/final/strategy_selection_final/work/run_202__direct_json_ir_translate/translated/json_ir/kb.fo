vocabulary V {
  type Person
  type Asset
  is_surviving_spouse_of: Person * Person -> Bool
  is_deceased: Person -> Bool
  leaves_descendants: Person -> Bool
  is_part_of_estate_of: Asset * Person -> Bool
  acquires_usufruct_of_entire_estate: Person * Person -> Bool
}

theory T:V {
  ! spouse in Person, deceased in Person: (((is_surviving_spouse_of(spouse,deceased)) & (is_deceased(deceased)) & (leaves_descendants(deceased)))) => ((acquires_usufruct_of_entire_estate(spouse,deceased))).
}
