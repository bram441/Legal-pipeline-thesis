{
  "types": [
    "Person",
    "Asset"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving spouse of the second (deceased) person.",
      "directly_observable": true
    },
    {
      "name": "is_deceased",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is deceased.",
      "directly_observable": true
    },
    {
      "name": "leaves_descendants",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased person leaves descendants (including adopted children or descendants of adopted children).",
      "directly_observable": true
    },
    {
      "name": "is_part_of_estate_of",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset forms part of the estate of the deceased person.",
      "directly_observable": true
    },
    {
      "name": "acquires_usufruct_of_entire_estate",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The first person (surviving spouse) acquires the usufruct of the entire estate of the second person (deceased) as a legal consequence.",
      "legal_output": true,
      "output_category": "right"
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_deceased",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "leaves_descendants",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct_of_entire_estate",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}