        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "More than one small-company criterion is exceeded for the company in the financial year."
    },
    {
      "name": "not_more_than_one_small_company_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "Not more than one small-company criterion is exceeded for the company in the financial year."
    },
    {
      "name": "is_last_closed_financial_year",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The financial year is the last closed financial year for the company on the balance sheet date."
    },
    {
      "name": "is_small_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "output_category": "classification",
      "description": "The company qualifies as a small company based on the last closed financial year."
    }
  ],
  "functions": [
    {
      "name": "annual_average_employees",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Int",
      "kind": "observable",
      "description": "The annual average number of employees of the company in the financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover excluding value added tax of the company in the financial year, in euro."
    },
    {
      "name": "balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The balance sheet total of the company in the financial year, in euro."
    }
  ],
