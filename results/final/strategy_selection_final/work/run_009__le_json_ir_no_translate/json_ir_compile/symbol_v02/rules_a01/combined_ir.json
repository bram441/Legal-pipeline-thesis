      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The employee criterion is exceeded for the company in the financial year (annual average employees > 50)."
    },
    {
      "name": "turnover_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The turnover criterion is exceeded for the company in the financial year (annual net turnover excluding VAT > 11,250,000 euro)."
    },
    {
      "name": "balance_sheet_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The balance sheet criterion is exceeded for the company in the financial year (balance sheet total > 6,000,000 euro)."
    },
