vocabulary V {
  type Company
  type FinancialYear
  has_legal_personality: Company -> Bool
  employee_criterion_exceeded: Company * FinancialYear -> Bool
  turnover_criterion_exceeded: Company * FinancialYear -> Bool
  balance_sheet_criterion_exceeded: Company * FinancialYear -> Bool
  more_than_one_criterion_exceeded: Company * FinancialYear -> Bool
  not_more_than_one_criterion_exceeded: Company * FinancialYear -> Bool
  following_financial_year: FinancialYear * FinancialYear -> Bool
  more_than_one_criterion_exceeded_second_consecutive_time: Company * FinancialYear -> Bool
  more_than_one_criterion_no_longer_exceeded_second_consecutive_time: Company * FinancialYear -> Bool
  more_than_one_criterion_exceeded_before: Company * FinancialYear -> Bool
  is_small_company: Company * FinancialYear -> Bool
  small_company_status_change_takes_effect_from: Company * FinancialYear -> Bool
  annual_average_employees: Company * FinancialYear -> Int
  annual_net_turnover_excl_vat: Company * FinancialYear -> Real
  balance_sheet_total: Company * FinancialYear -> Real
  last_closed_financial_year: Company -> FinancialYear
}

theory T:V {
  ! c in Company, fy in FinancialYear: ((annual_average_employees(c,fy) > 50)) => ((employee_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((annual_net_turnover_excl_vat(c,fy) > 11250000.0)) => ((turnover_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((balance_sheet_total(c,fy) > 6000000.0)) => ((balance_sheet_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((employee_criterion_exceeded(c,fy)) & (turnover_criterion_exceeded(c,fy)))) => ((more_than_one_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((employee_criterion_exceeded(c,fy)) & (balance_sheet_criterion_exceeded(c,fy)))) => ((more_than_one_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((turnover_criterion_exceeded(c,fy)) & (balance_sheet_criterion_exceeded(c,fy)))) => ((more_than_one_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((~more_than_one_criterion_exceeded(c,fy))) => ((not_more_than_one_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: ((more_than_one_criterion_exceeded(c,fy))) => ((~not_more_than_one_criterion_exceeded(c,fy))).
  ! c in Company, fy in FinancialYear: (((has_legal_personality(c)) & (not_more_than_one_criterion_exceeded(c,fy)))) => ((is_small_company(c,fy))).
  ! c in Company, fy in FinancialYear: ((more_than_one_criterion_exceeded(c,fy))) => ((~is_small_company(c,fy))).
  ! c in Company, y1 in FinancialYear, y2 in FinancialYear: (((more_than_one_criterion_exceeded(c,y1)) & (more_than_one_criterion_exceeded(c,y2)) & (following_financial_year(y1,y2)))) => ((more_than_one_criterion_exceeded_second_consecutive_time(c,y2))).
  ! c in Company, y1 in FinancialYear, y2 in FinancialYear: (((more_than_one_criterion_exceeded_before(c,y1)) & (not_more_than_one_criterion_exceeded(c,y1)) & (not_more_than_one_criterion_exceeded(c,y2)) & (following_financial_year(y1,y2)))) => ((more_than_one_criterion_no_longer_exceeded_second_consecutive_time(c,y2))).
  ! c in Company, y2 in FinancialYear, effect_year in FinancialYear: (((more_than_one_criterion_exceeded_second_consecutive_time(c,y2)) & (following_financial_year(y2,effect_year)))) => ((small_company_status_change_takes_effect_from(c,effect_year))).
  ! c in Company, y2 in FinancialYear, effect_year in FinancialYear: (((more_than_one_criterion_no_longer_exceeded_second_consecutive_time(c,y2)) & (following_financial_year(y2,effect_year)))) => ((small_company_status_change_takes_effect_from(c,effect_year))).
}
