{
  "rules": [
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"compare": {"left": {"func": "annual_average_employees", "args": ["c", "y"]}, "op": ">", "right": 50}}
      ],
      "then": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"compare": {"left": {"func": "annual_net_turnover_excl_vat", "args": ["c", "y"]}, "op": ">", "right": 11250000}}
      ],
      "then": [
        {"pred": "turnover_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"compare": {"left": {"func": "balance_sheet_total", "args": ["c", "y"]}, "op": ">", "right": 6000000}}
      ],
      "then": [
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "y"], "negated": false},
        {"pred": "turnover_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "y"], "negated": false},
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "turnover_criterion_exceeded", "args": ["c", "y"], "negated": false},
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": true}
      ],
      "then": [
        {"pred": "not_more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y1", "type": "FinancialYear"}, {"var": "y2", "type": "FinancialYear"}],
      "if": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "y1"], "negated": false},
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "y2"], "negated": false},
        {"pred": "following_financial_year", "args": ["y1", "y2"], "negated": false}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded_second_consecutive_time", "args": ["c", "y2"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y1", "type": "FinancialYear"}, {"var": "y2", "type": "FinancialYear"}],
      "if": [
        {"pred": "more_than_one_criterion_exceeded_before", "args": ["c", "y1"], "negated": false},
        {"pred": "not_more_than_one_criterion_exceeded", "args": ["c", "y1"], "negated": false},
        {"pred": "not_more_than_one_criterion_exceeded", "args": ["c", "y2"], "negated": false},
        {"pred": "following_financial_year", "args": ["y1", "y2"], "negated": false}
      ],
      "then": [
        {"pred": "more_than_one_criterion_no_longer_exceeded_second_consecutive_time", "args": ["c", "y2"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "has_legal_personality", "args": ["c"], "negated": false},
        {"pred": "not_more_than_one_criterion_exceeded", "args": ["c", {"func": "last_closed_financial_year", "args": ["c"]}], "negated": false}
      ],
      "then": [
        {"pred": "is_small_company", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", {"func": "last_closed_financial_year", "args": ["c"]}], "negated": false}
      ],
      "then": [
        {"pred": "is_small_company", "args": ["c", "y"], "negated": true}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y1", "type": "FinancialYear"}, {"var": "y2", "type": "FinancialYear"}],
      "if": [
        {"pred": "more_than_one_criterion_exceeded_second_consecutive_time", "args": ["c", "y1"], "negated": false},
        {"pred": "following_financial_year", "args": ["y1", "y2"], "negated": false}
      ],
      "then": [
        {"pred": "small_company_status_change_takes_effect_from", "args": ["c", "y2"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y1", "type": "FinancialYear"}, {"var": "y2", "type": "FinancialYear"}],
      "if": [
        {"pred": "more_than_one_criterion_no_longer_exceeded_second_consecutive_time", "args": ["c", "y1"], "negated": false},
        {"pred": "following_financial_year", "args": ["y1", "y2"], "negated": false}
      ],
      "then": [
        {"pred": "small_company_status_change_takes_effect_from", "args": ["c", "y2"], "negated": false}
      ],
      "operator": "implies"
    }
  ]
}