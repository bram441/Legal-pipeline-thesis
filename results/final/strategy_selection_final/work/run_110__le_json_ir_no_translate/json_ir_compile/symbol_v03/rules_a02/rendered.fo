vocabulary V {
  type Person
  type MemberState
  holds_belgian_nationality: Person -> Bool
  is_foreigner: Person -> Bool
  is_union_citizen: Person -> Bool
  falls_under_community_free_movement_law: Person -> Bool
  is_third_country_national: Person -> Bool
  present_on_territory: Person -> Bool
  satisfies_conditions_for_access_or_residence: Person -> Bool
  is_in_illegal_residence: Person -> Bool
  subject_to_removal_procedure: Person -> Bool
  subject_to_international_protection_procedure: Person -> Bool
  subject_to_dublin_determination_procedure: Person -> Bool
  subject_to_relevant_procedure: Person -> Bool
  individual_examination_performed: Person -> Bool
  objective_criterion_established: Person -> Bool
  risk_of_absconding_is_current_and_real: Person -> Bool
  risk_of_absconding: Person -> Bool
  has_valid_travel_document: Person -> Bool
  recognised_as_national_by_own_authority: Person -> Bool
  own_authority_willing_to_issue_laissez_passer: Person -> Bool
  falls_under_nationality_category_for_laissez_passer: Person -> Bool
  is_identified_foreigner: Person -> Bool
  absconding_criterion_1_met: Person -> Bool
  no_residence_application_after_illegal_entry_or_stay: Person -> Bool
  no_international_protection_request_within_period: Person -> Bool
  absconding_criterion_2_met: Person -> Bool
  used_false_information_or_documents: Person -> Bool
  committed_fraud_or_unlawful_means: Person -> Bool
  absconding_criterion_3_met: Person -> Bool
  does_not_cooperate_with_authorities: Person -> Bool
  absconding_criterion_4_met: Person -> Bool
  indicated_noncompliance_with_transfer_or_removal: Person -> Bool
  indicated_noncompliance_with_entry_ban: Person -> Bool
  indicated_noncompliance_with_less_coercive_measure: Person -> Bool
  indicated_noncompliance_with_freedom_restricting_measure: Person -> Bool
  indicated_noncompliance_with_equivalent_member_state_measure: Person -> Bool
  absconding_criterion_5_met: Person -> Bool
  subject_to_active_entry_ban: Person -> Bool
  absconding_criterion_6_met: Person -> Bool
  submitted_new_application_immediately_after_negative_decision: Person -> Bool
  absconding_criterion_7_met: Person -> Bool
  concealed_prior_fingerprints_in_dublin_state: Person -> Bool
  absconding_criterion_8_met: Person -> Bool
  submitted_multiple_applications_with_negative_outcomes: Person -> Bool
  absconding_criterion_9_met: Person -> Bool
  concealed_prior_protection_request_in_dublin_state: Person -> Bool
  absconding_criterion_10_met: Person -> Bool
  came_for_purposes_other_than_stated_application: Person -> Bool
  absconding_criterion_11_met: Person -> Bool
  subject_to_fine_for_manifestly_unlawful_appeal: Person -> Bool
  reasons_to_assume_will_abscond: Person -> Bool
}

theory T:V {
  ! p in Person: ((~holds_belgian_nationality(p))) => ((is_foreigner(p))).
  ! p in Person: ((~is_union_citizen(p)) & (~falls_under_community_free_movement_law(p))) => ((is_third_country_national(p))).
  ! p in Person: ((present_on_territory(p)) & (~satisfies_conditions_for_access_or_residence(p))) => ((is_in_illegal_residence(p))).
  ! p in Person: ((has_valid_travel_document(p))) => ((satisfies_conditions_for_access_or_residence(p))).
  ! p in Person: ((recognised_as_national_by_own_authority(p)) & (own_authority_willing_to_issue_laissez_passer(p))) => ((satisfies_conditions_for_access_or_residence(p))).
  ! p in Person: ((falls_under_nationality_category_for_laissez_passer(p))) => ((satisfies_conditions_for_access_or_residence(p))).
  ! p in Person: ((subject_to_removal_procedure(p))) => ((subject_to_relevant_procedure(p))).
  ! p in Person: ((subject_to_international_protection_procedure(p))) => ((subject_to_relevant_procedure(p))).
  ! p in Person: ((subject_to_dublin_determination_procedure(p))) => ((subject_to_relevant_procedure(p))).
  ! p in Person: ((no_residence_application_after_illegal_entry_or_stay(p))) => ((absconding_criterion_1_met(p))).
  ! p in Person: ((no_international_protection_request_within_period(p))) => ((absconding_criterion_1_met(p))).
  ! p in Person: ((used_false_information_or_documents(p))) => ((absconding_criterion_2_met(p))).
  ! p in Person: ((committed_fraud_or_unlawful_means(p))) => ((absconding_criterion_2_met(p))).
  ! p in Person: ((does_not_cooperate_with_authorities(p))) => ((absconding_criterion_3_met(p))).
  ! p in Person: ((indicated_noncompliance_with_transfer_or_removal(p))) => ((absconding_criterion_4_met(p))).
  ! p in Person: ((indicated_noncompliance_with_entry_ban(p))) => ((absconding_criterion_4_met(p))).
  ! p in Person: ((indicated_noncompliance_with_less_coercive_measure(p))) => ((absconding_criterion_4_met(p))).
  ! p in Person: ((indicated_noncompliance_with_freedom_restricting_measure(p))) => ((absconding_criterion_4_met(p))).
  ! p in Person: ((indicated_noncompliance_with_equivalent_member_state_measure(p))) => ((absconding_criterion_4_met(p))).
  ! p in Person: ((subject_to_active_entry_ban(p))) => ((absconding_criterion_5_met(p))).
  ! p in Person: ((submitted_new_application_immediately_after_negative_decision(p))) => ((absconding_criterion_6_met(p))).
  ! p in Person: ((concealed_prior_fingerprints_in_dublin_state(p))) => ((absconding_criterion_7_met(p))).
  ! p in Person: ((submitted_multiple_applications_with_negative_outcomes(p))) => ((absconding_criterion_8_met(p))).
  ! p in Person: ((concealed_prior_protection_request_in_dublin_state(p))) => ((absconding_criterion_9_met(p))).
  ! p in Person: ((came_for_purposes_other_than_stated_application(p))) => ((absconding_criterion_10_met(p))).
  ! p in Person: ((subject_to_fine_for_manifestly_unlawful_appeal(p))) => ((absconding_criterion_11_met(p))).
  ! p in Person: (((absconding_criterion_1_met(p)) | ((absconding_criterion_2_met(p)) | ((absconding_criterion_3_met(p)) | ((absconding_criterion_4_met(p)) | ((absconding_criterion_5_met(p)) | ((absconding_criterion_6_met(p)) | ((absconding_criterion_7_met(p)) | ((absconding_criterion_8_met(p)) | ((absconding_criterion_9_met(p)) | ((absconding_criterion_10_met(p)) | (absconding_criterion_11_met(p))))))))))))) => ((objective_criterion_established(p))).
  ! p in Person: ((has_valid_travel_document(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((recognised_as_national_by_own_authority(p)) & (own_authority_willing_to_issue_laissez_passer(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((falls_under_nationality_category_for_laissez_passer(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((reasons_to_assume_will_abscond(p)) & (subject_to_relevant_procedure(p)) & (individual_examination_performed(p)) & (objective_criterion_established(p)) & (risk_of_absconding_is_current_and_real(p))) => ((risk_of_absconding(p))).
}
