{
  "types": [
    "Person"
  ],
  "predicates": [
    {
      "name": "is_surviving_legal_cohabitant_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving legal cohabitant of the second (predeceased) person.",
      "directly_observable": true
    },
    {
      "name": "is_descendant_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is a descendant of the second person.",
      "directly_observable": true
    },
    {
      "name": "exception_applies_surviving_cohabitant_is_descendant",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The exception applies: the provisions of paragraphs 1 to 3 do not apply because the surviving legal cohabitant is a descendant of the predeceased legal cohabitant.",
      "legal_output": true,
      "output_category": "exception"
    },
    {
      "name": "paragraphs_1_to_3_apply",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The provisions of paragraphs 1 to 3 apply to the surviving legal cohabitant in relation to the predeceased legal cohabitant.",
      "legal_output": true,
      "output_category": "legal_effect"
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "survivor",
          "type": "Person"
        },
        {
          "var": "predeceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_legal_cohabitant_of",
              "args": [
                "survivor",
                "predeceased"
              ],
              "negated": false
            },
            {
              "pred": "is_descendant_of",
              "args": [
                "survivor",
                "predeceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "exception_applies_surviving_cohabitant_is_descendant",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "survivor",
          "type": "Person"
        },
        {
          "var": "predeceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_legal_cohabitant_of",
              "args": [
                "survivor",
                "predeceased"
              ],
              "negated": false
            },
            {
              "pred": "exception_applies_surviving_cohabitant_is_descendant",
              "args": [
                "survivor",
                "predeceased"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "paragraphs_1_to_3_apply",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
