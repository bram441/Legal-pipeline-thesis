vocabulary V {
  type Company
  type FinancialYear
  is_small_company_with_legal_personality: Company -> Bool
  is_subsidiary_company: Company -> Bool
  is_parent_company: Company -> Bool
  is_last_closed_financial_year: Company * FinancialYear -> Bool
  micro_employee_criterion_exceeded: Company * FinancialYear -> Bool
  micro_turnover_criterion_exceeded: Company * FinancialYear -> Bool
  micro_balance_sheet_criterion_exceeded: Company * FinancialYear -> Bool
  more_than_one_micro_criterion_exceeded: Company * FinancialYear -> Bool
  is_micro_company: Company -> Bool
  annual_average_employees: Company * FinancialYear -> Int
  annual_net_turnover_excl_vat: Company * FinancialYear -> Real
  balance_sheet_total: Company * FinancialYear -> Real
}

theory T:V {
  ! c in Company, y in FinancialYear: ((is_last_closed_financial_year(c,y)) & (~more_than_one_micro_criterion_exceeded(c,y))) => ((is_micro_company(c))).
  ! c in Company, y in FinancialYear: ((is_last_closed_financial_year(c,y)) & (more_than_one_micro_criterion_exceeded(c,y))) => ((~is_micro_company(c))).
  ! c in Company: ((is_subsidiary_company(c))) => ((~is_micro_company(c))).
  ! c in Company: ((is_parent_company(c))) => ((~is_micro_company(c))).
  ! c in Company, y in FinancialYear: ((annual_average_employees(c,y) > 10)) => ((micro_employee_criterion_exceeded(c,y))).
  ! c in Company, y in FinancialYear: ((annual_net_turnover_excl_vat(c,y) > 900000.0)) => ((micro_turnover_criterion_exceeded(c,y))).
  ! c in Company, y in FinancialYear: ((balance_sheet_total(c,y) > 450000.0)) => ((micro_balance_sheet_criterion_exceeded(c,y))).
  ! c in Company, y in FinancialYear: ((micro_employee_criterion_exceeded(c,y)) & (micro_turnover_criterion_exceeded(c,y))) => ((more_than_one_micro_criterion_exceeded(c,y))).
  ! c in Company, y in FinancialYear: ((micro_employee_criterion_exceeded(c,y)) & (micro_balance_sheet_criterion_exceeded(c,y))) => ((more_than_one_micro_criterion_exceeded(c,y))).
  ! c in Company, y in FinancialYear: ((micro_turnover_criterion_exceeded(c,y)) & (micro_balance_sheet_criterion_exceeded(c,y))) => ((more_than_one_micro_criterion_exceeded(c,y))).
}
