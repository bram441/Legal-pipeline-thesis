{
  "types": [
    "Person",
    "Estate"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The first person is the surviving spouse of the second (deceased) person."
    },
    {
      "name": "deceased_leaves_no_other_heirs",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deceased person leaves no other heirs."
    },
    {
      "name": "deceased_leaves_other_heirs",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The deceased person leaves other heirs besides the surviving spouse."
    },
    {
      "name": "other_heirs_reduce_surviving_spouse_right",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The other heirs left by the deceased are in a category that would reduce the surviving spouse to a lesser right under applicable inheritance rules."
    },
    {
      "name": "acquires_full_ownership_of_estate",
      "args": [
        "Person",
        "Estate"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires full ownership of the entire estate as a legal consequence.",
      "legal_output": true,
      "output_category": "legal_effect"
    },
    {
      "name": "estate_belongs_to_deceased",
      "args": [
        "Estate",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The estate belongs to the deceased person."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "estate",
          "type": "Estate"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "estate_belongs_to_deceased",
              "args": [
                "estate",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deceased_leaves_no_other_heirs",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_full_ownership_of_estate",
          "args": [
            "spouse",
            "estate"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "estate",
          "type": "Estate"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "estate_belongs_to_deceased",
              "args": [
                "estate",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deceased_leaves_other_heirs",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "other_heirs_reduce_surviving_spouse_right",
              "args": [
                "deceased"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_full_ownership_of_estate",
          "args": [
            "spouse",
            "estate"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}