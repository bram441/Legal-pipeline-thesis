        {
          "and": [
            {"pred": "is_surviving_spouse_of", "args": ["spouse", "deceased"], "negated": false},
            {"pred": "is_deceased", "args": ["deceased"], "negated": false},
            {"pred": "deceased_leaves_qualifying_relatives", "args": ["deceased"], "negated": false},
            {"pred": "is_common_property", "args": ["asset", "deceased"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "acquires_full_ownership_of_share", "args": ["spouse", "asset"], "negated": false}
      ],
      "operator": "implies"
    },
