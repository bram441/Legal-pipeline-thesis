{
  "rules": [
    {
      "forall": [
        {"var": "deceased", "type": "Person"},
        {"var": "spouse", "type": "Person"}
      ],
      "if": [
        {
          "or": [
            {"pred": "deceased_leaves_ascending_relatives", "args": ["deceased"], "negated": false},
            {"pred": "deceased_leaves_close_collateral_relatives", "args": ["deceased"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "deceased_leaves_qualifying_relatives", "args": ["deceased"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "asset", "type": "Asset"}
      ],
      "if": [
        {
          "or": [
            {"pred": "deed_of_donation_excludes_usufruct", "args": ["asset"], "negated": false},
            {"pred": "will_excludes_usufruct", "args": ["asset"], "negated": false}
          ]
        }
      ],
      "then": [
        {"pred": "usufruct_of_legal_reversion_asset_excluded", "args": ["asset"], "negated": false}
      ],
      "operator": "implies"
    },
    {
