{
  "types": [
    "Person",
    "Asset"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving spouse of the second (deceased) person.",
      "directly_observable": true
    },
    {
      "name": "is_deceased",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is deceased.",
      "directly_observable": true
    },
    {
      "name": "deceased_leaves_ascending_relatives",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased leaves relatives in the ascending line.",
      "directly_observable": true
    },
    {
      "name": "deceased_leaves_close_collateral_relatives",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased leaves close collateral relatives.",
      "directly_observable": true
    },
    {
      "name": "is_common_property",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is part of the common property of the deceased person.",
      "directly_observable": true
    },
    {
      "name": "is_undivided_co_ownership_between_spouses",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is held exclusively in undivided co-ownership between the spouses of the deceased.",
      "directly_observable": true
    },
    {
      "name": "is_own_property_of_deceased",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is the own (separate) property of the deceased person.",
      "directly_observable": true
    },
    {
      "name": "is_subject_to_legal_reversion",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is subject to the right of legal reversion under article 4.24 or 4.25 in the estate of the deceased.",
      "directly_observable": true
    },
    {
      "name": "deed_of_donation_excludes_usufruct",
      "args": [
        "Asset"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deed of donation provides otherwise, excluding the surviving spouse's usufruct over the asset subject to legal reversion.",
      "directly_observable": true
    },
    {
      "name": "will_excludes_usufruct",
      "args": [
        "Asset"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The will provides otherwise, excluding the surviving spouse's usufruct over the asset subject to legal reversion.",
      "directly_observable": true
    },
    {
      "name": "deceased_leaves_qualifying_relatives",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The deceased leaves relatives in the ascending line or close collateral relatives."
    },
    {
      "name": "usufruct_of_legal_reversion_asset_excluded",
      "args": [
        "Asset"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The usufruct over the asset subject to legal reversion is excluded by the deed of donation or the will."
    },
    {
      "name": "acquires_full_ownership_of_share",
      "args": [
        "Person",
        "Asset"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires full ownership of the deceased's share in the asset (common property or undivided co-ownership between spouses).",
      "legal_output": true,
      "output_category": "legal_effect"
    },
    {
      "name": "acquires_usufruct_of_own_property",
      "args": [
        "Person",
        "Asset"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires usufruct of the asset that is the deceased's own (separate) property.",
      "legal_output": true,
      "output_category": "legal_effect"
    },
    {
      "name": "acquires_usufruct_of_legal_reversion_asset",
      "args": [
        "Person",
        "Asset"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires usufruct of the asset subject to the right of legal reversion, unless excluded by the deed of donation or will.",
      "legal_output": true,
      "output_category": "legal_effect"
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "spouse",
          "type": "Person"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "deceased_leaves_ascending_relatives",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deceased_leaves_close_collateral_relatives",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "deceased_leaves_qualifying_relatives",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
        {
          "or": [
            {
              "pred": "deed_of_donation_excludes_usufruct",
              "args": [
                "asset"
              ],
              "negated": false
            },
            {
              "pred": "will_excludes_usufruct",
              "args": [
                "asset"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "usufruct_of_legal_reversion_asset_excluded",
          "args": [
            "asset"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
