vocabulary V {
  type Person
  type Procedure
  type Document
  type Measure
  type MemberState
  is_foreigner: Person -> Bool
  is_third_country_national: Person -> Bool
  in_illegal_residence: Person -> Bool
  subject_to_removal_procedure: Person -> Bool
  subject_to_international_protection_procedure: Person -> Bool
  subject_to_responsibility_determination_procedure: Person -> Bool
  individual_examination_performed: Person -> Bool
  no_residence_application_after_illegal_entry_or_stay: Person -> Bool
  used_false_information_or_documents: Person -> Bool
  failed_to_cooperate_with_authorities: Person -> Bool
  indicated_unwillingness_to_comply_with_measure: Person -> Bool
  subject_to_active_entry_ban: Person -> Bool
  filed_new_application_immediately_after_negative_decision: Person -> Bool
  concealed_prior_fingerprints_in_other_state: Person -> Bool
  multiple_applications_with_negative_outcome: Person -> Bool
  concealed_prior_protection_request_in_other_state: Person -> Bool
  entered_for_purposes_other_than_stated_application: Person -> Bool
  fined_for_manifestly_unfounded_appeal: Person -> Bool
  is_identified_foreigner: Person -> Bool
  holds_valid_travel_document: Person -> Bool
  recognised_by_national_authority_with_laissez_passer: Person -> Bool
  nationality_eligible_for_ministerial_laissez_passer: Person -> Bool
  risk_of_absconding: Person -> Bool
  at_least_one_criterion_met: Person -> Bool
}

theory T:V {
  ! p in Person: ((holds_valid_travel_document(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((recognised_by_national_authority_with_laissez_passer(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((nationality_eligible_for_ministerial_laissez_passer(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((no_residence_application_after_illegal_entry_or_stay(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((used_false_information_or_documents(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((failed_to_cooperate_with_authorities(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((indicated_unwillingness_to_comply_with_measure(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((subject_to_active_entry_ban(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((filed_new_application_immediately_after_negative_decision(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((concealed_prior_fingerprints_in_other_state(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((multiple_applications_with_negative_outcome(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((concealed_prior_protection_request_in_other_state(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((entered_for_purposes_other_than_stated_application(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: ((fined_for_manifestly_unfounded_appeal(p))) => ((at_least_one_criterion_met(p))).
  ! p in Person: (((individual_examination_performed(p)) & (at_least_one_criterion_met(p)) & ((subject_to_removal_procedure(p)) | (subject_to_international_protection_procedure(p)) | (subject_to_responsibility_determination_procedure(p))))) => ((risk_of_absconding(p))).
}
