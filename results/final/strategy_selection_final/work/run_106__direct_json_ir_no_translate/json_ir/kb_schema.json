{
  "types": [
    "Person",
    "Property"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving spouse of the second person (the deceased).",
      "directly_observable": true
    },
    {
      "name": "is_heir_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is an heir of the second person (the deceased).",
      "directly_observable": true
    },
    {
      "name": "served_as_main_family_residence_at_opening_of_estate",
      "args": [
        "Property",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property served as the main family residence at the time the estate of the deceased opened.",
      "directly_observable": true
    },
    {
      "name": "is_rented_property",
      "args": [
        "Property"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property is subject to a lease (huur) at the time of the opening of the estate.",
      "directly_observable": true
    },
    {
      "name": "acquires_right_to_lease",
      "args": [
        "Person",
        "Property"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person acquires the exclusive right to the lease of the property, to the exclusion of all other heirs, as the surviving spouse.",
      "legal_output": true,
      "output_category": "right"
    },
    {
      "name": "excluded_from_lease_right",
      "args": [
        "Person",
        "Property"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person (heir) is excluded from the right to the lease of the property because the surviving spouse holds that right exclusively.",
      "output_category": "exception"
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "property",
          "type": "Property"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "served_as_main_family_residence_at_opening_of_estate",
              "args": [
                "property",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_rented_property",
              "args": [
                "property"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_right_to_lease",
          "args": [
            "spouse",
            "property"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "heir",
          "type": "Person"
        },
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "property",
          "type": "Property"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_heir_of",
              "args": [
                "heir",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "acquires_right_to_lease",
              "args": [
                "spouse",
                "property"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "excluded_from_lease_right",
          "args": [
            "heir",
            "property"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}