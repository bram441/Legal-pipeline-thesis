      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds more than one of the three listed criteria in the financial year."
    },
    {
      "name": "is_small_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "output_category": "classification",
      "description": "The company qualifies as a small company with legal personality in the given financial year under the statutory criteria."
    },
    {
      "name": "criteria_must_be_taken_into_account_immediately",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "output_category": "legal_effect",
      "description": "The exceeding of more than one criterion must be taken into account immediately for the first financial year, because the good-faith estimate at the start of that year indicated that more than one criterion would be exceeded."
    }
  ],
  "functions": [
    {
      "name": "annual_average_employees",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Int",
      "kind": "observable",
      "description": "The annual average number of employees of the company in the financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
