    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "annual_average_employees",
              "args": [
