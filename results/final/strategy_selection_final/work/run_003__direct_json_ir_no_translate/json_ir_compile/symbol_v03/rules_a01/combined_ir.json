{
  "types": [
    "Company",
    "FinancialYear"
  ],
  "predicates": [
    {
      "name": "has_legal_personality",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company has legal personality (rechtspersoonlijkheid)."
    },
    {
      "name": "is_small_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company qualifies as a small company (kleine vennootschap) in the given financial year."
    },
    {
      "name": "is_subsidiary",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company is a subsidiary (dochtervennootschap) of another company."
    },
    {
      "name": "is_parent_company",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company is a parent company (moedervennootschap) of another company."
    },
    {
      "name": "employee_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual average employee threshold of 10 in the financial year."
    },
    {
      "name": "turnover_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual net turnover threshold of 900,000 EUR (excluding VAT) in the financial year."
    },
    {
      "name": "balance_sheet_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the balance sheet total threshold of 450,000 EUR in the financial year."
    },
    {
      "name": "more_than_one_micro_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds more than one of the three micro-company criteria in the given financial year."
    },
    {
      "name": "previous_financial_year",
      "args": [
        "FinancialYear",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The second argument is the financial year immediately preceding the first argument."
    },
    {
      "name": "next_financial_year",
      "args": [
        "FinancialYear",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The second argument is the financial year immediately following the first argument."
    },
    {
      "name": "is_micro_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "output_category": "classification",
      "description": "The company qualifies as a micro-company (microvennootschap) under Art. 1:25 in the given financial year. Determined solely by conditions observable on the company and that financial year, without requiring a witness year variable in the conclusion."
    }
  ],
  "functions": [
    {
      "name": "annual_average_employees",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Int",
      "kind": "observable",
      "description": "The annual average number of employees of the company in the financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover of the company excluding VAT in the financial year, in EUR."
    },
    {
      "name": "balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The balance sheet total of the company at the balance sheet date of the financial year, in EUR."
    }
  ],
  "rules": [
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "annual_average_employees",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 10
          }
        }
      ],
      "then": [
        {
          "pred": "employee_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "annual_net_turnover_excl_vat",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 900000.0
          }
        }
      ],
      "then": [
        {
          "pred": "turnover_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
