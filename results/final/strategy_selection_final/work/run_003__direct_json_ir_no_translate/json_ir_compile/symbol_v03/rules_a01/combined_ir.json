                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 450000.0
          }
        }
      ],
      "then": [
        {
          "pred": "balance_sheet_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
