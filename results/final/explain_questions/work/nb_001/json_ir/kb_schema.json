{
  "types": [
    "Person",
    "Asset",
    "Estate"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving spouse of the second person (the deceased). This status may be directly asserted by a case.",
      "directly_observable": true
    },
    {
      "name": "deceased_leaves_descendants_or_adopted_children",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased leaves descendants, adopted children, or descendants of adopted children.",
      "directly_observable": true
    },
    {
      "name": "deceased_leaves_ascendants_or_close_collaterals",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased leaves relatives in the ascending line or close collateral relatives.",
      "directly_observable": true
    },
    {
      "name": "deceased_leaves_other_or_no_heirs",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased leaves only other heirs or no heirs at all.",
      "directly_observable": true
    },
    {
      "name": "asset_is_in_common_estate",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset belongs to the common matrimonial estate of the deceased.",
      "directly_observable": true
    },
    {
      "name": "asset_is_in_exclusive_undivided_estate",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset belongs to the estate held exclusively in undivided co-ownership between the spouses.",
      "directly_observable": true
    },
    {
      "name": "asset_is_in_own_estate",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset belongs to the deceased's own (separate) estate, excluding common and exclusive undivided assets.",
      "directly_observable": true
    },
    {
      "name": "asset_subject_to_legal_return",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is subject to the right of legal return as referred to in article 4.24 or 4.25.",
      "directly_observable": true
    },
    {
      "name": "deed_or_testament_excludes_usufruct_on_return_asset",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deed of gift or testament provides otherwise regarding the usufruct on the asset subject to legal return.",
      "directly_observable": true
    },
    {
      "name": "acquires_usufruct_of_entire_estate",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires usufruct of the entire estate of the deceased.",
      "legal_output": true,
      "output_category": "legal_effect"
    },
    {
      "name": "acquires_full_ownership_of_common_share",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires full ownership of the deceased's share in the common and exclusive undivided estate.",
      "legal_output": true,
      "output_category": "legal_effect"
    },
    {
      "name": "acquires_usufruct_of_own_estate_assets",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires usufruct of the remaining assets in the deceased's own estate.",
      "legal_output": true,
      "output_category": "legal_effect"
    },
    {
      "name": "acquires_usufruct_of_legal_return_asset",
      "args": [
        "Person",
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires usufruct over the specific asset subject to legal return of the deceased.",
      "legal_output": true,
      "output_category": "legal_effect"
    },
    {
      "name": "acquires_full_ownership_of_entire_estate",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse acquires full ownership of the entire estate of the deceased.",
      "legal_output": true,
      "output_category": "legal_effect"
    },
    {
      "name": "par1_scenario_applies",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The scenario of paragraph 1 applies: the deceased leaves descendants or adopted children."
    },
    {
      "name": "par2_scenario_applies",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The scenario of paragraph 2 applies: the deceased leaves ascendants or close collaterals but no descendants or adopted children."
    },
    {
      "name": "par3_scenario_applies",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The scenario of paragraph 3 applies: the deceased leaves other heirs or no heirs, and neither par1 nor par2 applies."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "deceased_leaves_descendants_or_adopted_children",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "par1_scenario_applies",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "deceased_leaves_ascendants_or_close_collaterals",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deceased_leaves_descendants_or_adopted_children",
              "args": [
                "deceased"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "par2_scenario_applies",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "deceased_leaves_other_or_no_heirs",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deceased_leaves_descendants_or_adopted_children",
              "args": [
                "deceased"
              ],
              "negated": true
            },
            {
              "pred": "deceased_leaves_ascendants_or_close_collaterals",
              "args": [
                "deceased"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "par3_scenario_applies",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "par1_scenario_applies",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct_of_entire_estate",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "par2_scenario_applies",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_full_ownership_of_common_share",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "par2_scenario_applies",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct_of_own_estate_assets",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "par2_scenario_applies",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "asset_subject_to_legal_return",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deed_or_testament_excludes_usufruct_on_return_asset",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct_of_legal_return_asset",
          "args": [
            "spouse",
            "asset",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "par3_scenario_applies",
              "args": [
                "deceased"
              ],
              "negated": false
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "acquires_full_ownership_of_entire_estate",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}