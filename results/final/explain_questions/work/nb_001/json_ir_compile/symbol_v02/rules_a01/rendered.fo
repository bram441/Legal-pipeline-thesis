vocabulary V {
  type Person
  type Asset
  type Estate
  is_surviving_spouse_of: Person * Person -> Bool
  deceased_leaves_descendants_or_adopted_children: Person -> Bool
  deceased_leaves_ascendants_or_close_collaterals: Person -> Bool
  deceased_leaves_other_or_no_heirs: Person -> Bool
  asset_is_in_common_estate: Asset * Person -> Bool
  asset_is_in_exclusive_undivided_estate: Asset * Person -> Bool
  asset_is_in_own_estate: Asset * Person -> Bool
  asset_subject_to_legal_return: Asset * Person -> Bool
  deed_or_testament_excludes_usufruct_on_return_asset: Asset * Person -> Bool
  acquires_usufruct_of_entire_estate: Person * Person -> Bool
  acquires_full_ownership_of_common_share: Person * Person -> Bool
  acquires_usufruct_of_own_estate_assets: Person * Person -> Bool
  acquires_usufruct_of_legal_return_asset: Person * Asset * Person -> Bool
  acquires_full_ownership_of_entire_estate: Person * Person -> Bool
  par1_scenario_applies: Person -> Bool
  par2_scenario_applies: Person -> Bool
  par3_scenario_applies: Person -> Bool
}

theory T:V {
  ! deceased in Person: ((deceased_leaves_descendants_or_adopted_children(deceased))) => ((par1_scenario_applies(deceased))).
  ! deceased in Person: (((deceased_leaves_ascendants_or_close_collaterals(deceased)) & (~deceased_leaves_descendants_or_adopted_children(deceased)))) => ((par2_scenario_applies(deceased))).
  ! deceased in Person: (((deceased_leaves_other_or_no_heirs(deceased)) & (~deceased_leaves_descendants_or_adopted_children(deceased)) & (~deceased_leaves_ascendants_or_close_collaterals(deceased)))) => ((par3_scenario_applies(deceased))).
  ! spouse in Person, deceased in Person: (((is_surviving_spouse_of(spouse,deceased)) & (par1_scenario_applies(deceased)))) => ((acquires_usufruct_of_entire_estate(spouse,deceased))).
  ! spouse in Person, deceased in Person: (((is_surviving_spouse_of(spouse,deceased)) & (par2_scenario_applies(deceased)))) => ((acquires_full_ownership_of_common_share(spouse,deceased))).
  ! spouse in Person, deceased in Person: (((is_surviving_spouse_of(spouse,deceased)) & (par2_scenario_applies(deceased)))) => ((acquires_usufruct_of_own_estate_assets(spouse,deceased))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (par2_scenario_applies(deceased)) & (asset_subject_to_legal_return(asset,deceased)) & (~deed_or_testament_excludes_usufruct_on_return_asset(asset,deceased)))) => ((acquires_usufruct_of_legal_return_asset(spouse,asset,deceased))).
  ! spouse in Person, deceased in Person: (((is_surviving_spouse_of(spouse,deceased)) & (par3_scenario_applies(deceased)))) => ((acquires_full_ownership_of_entire_estate(spouse,deceased))).
}
