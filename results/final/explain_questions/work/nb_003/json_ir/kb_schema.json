{
  "types": [
    "Person",
    "Asset",
    "Estate"
  ],
  "predicates": [
    {
      "name": "is_surviving_spouse_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving spouse of the second person (the deceased). This status may be directly asserted by a case.",
      "directly_observable": true
    },
    {
      "name": "deceased_leaves_descendants_or_adopted_children",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased leaves descendants, adopted children, or descendants of adopted children.",
      "directly_observable": true
    },
    {
      "name": "deceased_leaves_ascendants_or_close_collaterals",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased leaves relatives in the ascending line or close collateral relatives.",
      "directly_observable": true
    },
    {
      "name": "deceased_leaves_other_or_no_heirs",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deceased leaves only other heirs or no heirs at all.",
      "directly_observable": true
    },
    {
      "name": "asset_is_part_of_common_property",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset forms part of the common matrimonial property of the deceased.",
      "directly_observable": true
    },
    {
      "name": "asset_is_exclusively_undivided_between_spouses",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is exclusively held in undivided co-ownership between the spouses.",
      "directly_observable": true
    },
    {
      "name": "asset_is_own_property_of_deceased",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset belongs to the own (separate) property of the deceased.",
      "directly_observable": true
    },
    {
      "name": "asset_subject_to_legal_return_right",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The asset is subject to the right of legal return as referred to in article 4.24 or 4.25.",
      "directly_observable": true
    },
    {
      "name": "deed_or_will_excludes_usufruct_on_return_asset",
      "args": [
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The deed of gift or testament provides otherwise regarding usufruct on the asset subject to legal return.",
      "directly_observable": true
    },
    {
      "name": "acquires_usufruct_of_entire_estate",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse (first person) acquires usufruct of the entire estate of the deceased (second person).",
      "legal_output": true
    },
    {
      "name": "acquires_full_ownership_of_common_share",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse (first person) acquires full ownership of the deceased's (second person) share in the common and exclusively undivided property.",
      "legal_output": true
    },
    {
      "name": "acquires_usufruct_of_own_property",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse (first person) acquires usufruct of the remaining own property of the deceased (second person).",
      "legal_output": true
    },
    {
      "name": "acquires_usufruct_of_return_asset",
      "args": [
        "Person",
        "Asset",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse (first person) acquires usufruct of the asset subject to legal return belonging to the deceased (third person).",
      "legal_output": true
    },
    {
      "name": "acquires_full_ownership_of_entire_estate",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving spouse (first person) acquires full ownership of the entire estate of the deceased (second person).",
      "legal_output": true
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_surviving_spouse_of",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "deceased_leaves_descendants_or_adopted_children",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct_of_entire_estate",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_surviving_spouse_of",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "deceased_leaves_ascendants_or_close_collaterals",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "acquires_full_ownership_of_common_share",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_surviving_spouse_of",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "deceased_leaves_ascendants_or_close_collaterals",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct_of_own_property",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        },
        {
          "var": "asset",
          "type": "Asset"
        }
      ],
      "if": [
        {
          "pred": "is_surviving_spouse_of",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "deceased_leaves_ascendants_or_close_collaterals",
          "args": [
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "asset_subject_to_legal_return_right",
          "args": [
