            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "deed_or_will_excludes_usufruct_on_return_asset",
          "args": [
            "asset",
            "deceased"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "acquires_usufruct_of_return_asset",
