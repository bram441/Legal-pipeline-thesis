      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "spouse",
          "type": "Person"
        },
        {
          "var": "deceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_surviving_spouse_of",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        },
        {
          "pred": "deceased_leaves_other_or_no_heirs",
          "args": [
            "deceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "acquires_full_ownership_of_entire_estate",
          "args": [
            "spouse",
            "deceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}