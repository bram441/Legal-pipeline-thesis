      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "risk_of_absconding_current_and_real",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "risk_of_absconding",
          "args": [
            "p"
          ],
          "negated": false
        }
