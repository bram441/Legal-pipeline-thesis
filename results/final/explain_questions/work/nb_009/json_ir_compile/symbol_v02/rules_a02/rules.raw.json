{
  "rules": [
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "has_non_standard_duration", "args": ["fy"], "negated": false},
        {"compare": {"left": {"func": "annual_net_turnover_excl_vat", "args": ["c", "fy"]}, "op": ">", "right": {"func": "adjusted_turnover_threshold", "args": ["fy"]}}}
      ],
      "then": [
        {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "has_non_standard_duration", "args": ["fy"], "negated": true},
        {"compare": {"left": {"func": "annual_net_turnover_excl_vat", "args": ["c", "fy"]}, "op": ">", "right": 11250000.0}}
      ],
      "then": [
        {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "has_non_standard_duration", "args": ["fy"], "negated": false}
      ],
      "then": [
        {"compare": {"left": {"func": "adjusted_turnover_threshold", "args": ["fy"]}, "op": "=", "right": {"func": "adjusted_turnover_threshold", "args": ["fy"]}}}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"compare": {"left": {"func": "annual_average_employees", "args": ["c", "fy"]}, "op": ">", "right": 50}}
      ],
      "then": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"compare": {"left": {"func": "balance_sheet_total", "args": ["c", "fy"]}, "op": ">", "right": 6000000.0}}
      ],
      "then": [
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"or": [
          {"and": [
            {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false},
            {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false}
          ]},
          {"and": [
            {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false},
            {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "fy"], "negated": false}
          ]},
          {"and": [
            {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false},
            {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "fy"], "negated": false}
          ]}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "has_legal_personality", "args": ["c"], "negated": false},
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": true}
      ],
      "then": [
        {"pred": "is_kleine_vennootschap", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "fy", "type": "FinancialYear"}],
      "if": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "then": [
        {"pred": "is_kleine_vennootschap", "args": ["c", "fy"], "negated": true}
      ],
      "operator": "implies"
    }
  ]
}