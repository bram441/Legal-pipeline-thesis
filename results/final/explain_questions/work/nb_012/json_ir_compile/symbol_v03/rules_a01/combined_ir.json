        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "output_category": "classification",
      "description": "The company qualifies as a micro-company (microvennootschap) in the given financial year. The financial year is the most recently closed financial year at balance sheet date."
    },
    {
      "name": "previous_financial_year",
      "args": [
        "FinancialYear",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The second financial year argument is immediately before the first financial year argument."
    },
    {
      "name": "next_financial_year",
      "args": [
        "FinancialYear",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
