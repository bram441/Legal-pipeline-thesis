    {
      "name": "turnover_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual net turnover threshold of 900,000 EUR (excluding VAT) in the financial year."
    },
    {
      "name": "balance_sheet_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
