    {
      "name": "micro_company_status_change_applies_from",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "output_category": "timing",
      "legal_output": true,
      "description": "A change in micro-company status takes effect for the company from this financial year, following two consecutive years of exceeding or ceasing to exceed more than one criterion."
