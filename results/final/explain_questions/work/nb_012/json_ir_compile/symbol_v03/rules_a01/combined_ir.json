    {
      "name": "qualifies_as_micro_in_last_closed_year",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "Observable Boolean condition: the company satisfies all micro-company criteria in the most recently closed financial year linked to the assessment year, without requiring a separate financial year variable in the conclusion."
    }
