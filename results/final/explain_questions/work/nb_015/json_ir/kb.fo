vocabulary V {
  type Person
  type Document
  type Procedure
  type Measure
  type State
  is_belgian_national: Person -> Bool
  is_foreigner: Person -> Bool
  is_union_citizen: Person -> Bool
  falls_under_free_movement_law: Person -> Bool
  is_third_country_national: Person -> Bool
  meets_entry_or_residence_conditions: Person -> Bool
  is_in_illegal_residence: Person -> Bool
  subject_to_removal_procedure: Person -> Bool
  subject_to_international_protection_procedure: Person -> Bool
  subject_to_responsibility_determination_procedure: Person -> Bool
  individual_examination_performed: Person -> Bool
  risk_of_absconding: Person -> Bool
  no_residence_application_filed_after_illegal_entry_or_during_illegal_stay: Person -> Bool
  used_false_or_misleading_information_or_documents: Person -> Bool
  does_not_cooperate_with_authorities: Person -> Bool
  indicated_unwillingness_to_comply_with_measure: Person -> Bool
  subject_to_active_entry_ban: Person -> Bool
  filed_new_application_immediately_after_negative_decision: Person -> Bool
  concealed_prior_fingerprints_in_other_state: Person -> Bool
  multiple_applications_with_negative_outcome: Person -> Bool
  concealed_prior_protection_request_in_other_state: Person -> Bool
  came_for_purposes_other_than_stated_application: Person -> Bool
  fined_for_manifestly_unfounded_appeal: Person -> Bool
  holds_valid_travel_document: Person -> Bool
  recognised_by_national_authority_of_origin_state: Person -> Bool
  falls_under_nationality_category_for_ministerial_laissez_passer: Person -> Bool
  is_identified_foreigner: Person -> Bool
  risk_criterion_applies: Person -> Bool
}

theory T:V {
  ! p in Person: ((~is_belgian_national(p))) => ((is_foreigner(p))).
  ! p in Person: (((~is_union_citizen(p)) & (~falls_under_free_movement_law(p)))) => ((is_third_country_national(p))).
  ! p in Person: ((~meets_entry_or_residence_conditions(p))) => ((is_in_illegal_residence(p))).
  ! p in Person: ((holds_valid_travel_document(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((recognised_by_national_authority_of_origin_state(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((falls_under_nationality_category_for_ministerial_laissez_passer(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((no_residence_application_filed_after_illegal_entry_or_during_illegal_stay(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((used_false_or_misleading_information_or_documents(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((does_not_cooperate_with_authorities(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((indicated_unwillingness_to_comply_with_measure(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((subject_to_active_entry_ban(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((filed_new_application_immediately_after_negative_decision(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((concealed_prior_fingerprints_in_other_state(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((multiple_applications_with_negative_outcome(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((concealed_prior_protection_request_in_other_state(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((came_for_purposes_other_than_stated_application(p))) => ((risk_criterion_applies(p))).
  ! p in Person: ((fined_for_manifestly_unfounded_appeal(p))) => ((risk_criterion_applies(p))).
  ! p in Person: (((is_foreigner(p)) & ((subject_to_removal_procedure(p)) | (subject_to_international_protection_procedure(p)) | (subject_to_responsibility_determination_procedure(p))) & (individual_examination_performed(p)) & (risk_criterion_applies(p)))) => ((risk_of_absconding(p))).
}
