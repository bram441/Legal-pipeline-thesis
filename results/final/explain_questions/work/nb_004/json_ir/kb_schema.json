      "output_category": "legal_effect"
    },
    {
      "name": "acquires_usufruct_of_household_contents",
      "args": [
        "Person",
        "Property"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving legal cohabitant acquires usufruct over the household contents by operation of law.",
