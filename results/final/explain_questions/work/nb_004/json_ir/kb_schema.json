      "name": "donation_reserved_usufruct",
      "args": [
        "Donation",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The donor reserved the usufruct of the donated property at the time of the donation.",
      "directly_observable": true
    },
    {
      "name": "cohabitant_status_at_time_of_donation",
      "args": [
        "Person",
        "Donation"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The surviving person already had the status of legal cohabitant at the time of the donation.",
      "directly_observable": true
    },
    {
      "name": "donor_remained_usufruct_holder_until_death",
      "args": [
        "Person",
        "Donation"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The donor remained the holder of the reserved usufruct until the day of death.",
      "directly_observable": true
    },
    {
      "name": "donation_subject_property_is_main_residence",
      "args": [
        "Donation",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property subject to the donation served as the main family residence at the time the estate opened.",
      "directly_observable": true
    },
    {
      "name": "surviving_cohabitant_renounces_usufruct",
      "args": [
        "Person",
        "Donation"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The surviving legal cohabitant renounces the usufruct arising from the donation provision.",
      "directly_observable": true
    },
    {
      "name": "renunciation_occurs_during_donors_lifetime",
      "args": [
        "Person",
        "Donation"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The renunciation of usufruct takes place during the lifetime of the donor.",
      "directly_observable": true
    },
    {
      "name": "bare_ownership_acquired_by",
      "args": [
        "Person",
        "Property"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person acquires bare ownership of the property.",
      "directly_observable": true
    },
    {
      "name": "exclusion_applies_descendant",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The exclusion applies because the surviving legal cohabitant is a descendant of the deceased cohabitant, blocking inheritance rights under the article."
    },
    {
      "name": "acquires_usufruct_of_main_residence",
      "args": [
        "Person",
        "Property"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving legal cohabitant acquires usufruct over the main family residence property by operation of law.",
