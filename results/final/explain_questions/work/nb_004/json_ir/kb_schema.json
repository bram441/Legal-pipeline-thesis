  "predicates": [
    {
      "name": "is_legal_cohabitant_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the legally cohabiting partner of the second person.",
      "directly_observable": true
    },
    {
      "name": "is_surviving_cohabitant",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving legal cohabitant of the deceased second person.",
      "directly_observable": true
    },
    {
      "name": "is_descendant_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is a descendant of the second person.",
      "directly_observable": true
    },
    {
      "name": "is_main_family_residence",
      "args": [
        "Property",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property served as the main family residence of the deceased at the time the estate opened.",
      "directly_observable": true
    },
    {
      "name": "is_household_contents_of",
      "args": [
        "Property",
        "Property"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first property represents the household contents present in the second property.",
      "directly_observable": true
    },
    {
      "name": "subject_to_legal_return_right",
      "args": [
        "Property"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property is subject to a right of legal return as referred to in the applicable articles.",
      "directly_observable": true
    },
    {
      "name": "is_rented_property",
      "args": [
        "Property"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The property is held under a rental agreement.",
      "directly_observable": true
    },
