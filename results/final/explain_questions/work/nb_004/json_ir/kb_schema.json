      "output_category": "legal_effect"
    },
    {
      "name": "acquires_usufruct_from_donation",
      "args": [
        "Person",
        "Donation"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving legal cohabitant acquires usufruct of the donated property upon the donor's death.",
      "legal_output": true,
      "output_category": "legal_effect"
    },
    {
      "name": "acquires_rental_right_of_main_residence",
      "args": [
        "Person",
        "Property"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The surviving legal cohabitant acquires the exclusive right to the rental of the main family residence, to the exclusion of all other heirs.",
