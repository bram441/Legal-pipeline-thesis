    }
  ],
  "functions": [
    {
      "name": "annual_average_employees_fte",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual average number of employees expressed in full-time equivalents for the company in the financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover excluding VAT of the company in the financial year (in euros)."
    },
    {
      "name": "balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The total book value of assets (balanstotaal) of the company in the financial year (in euros)."
    },
    {
      "name": "total_operating_and_financial_revenues_excl_nonrecurrent",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The total of operating and financial revenues excluding non-recurrent revenues, used as alternative net turnover when ordinary revenues are mostly non-turnover (in euros)."
    },
    {
      "name": "consolidated_annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The consolidated annual net turnover excluding VAT for the group of linked companies in the financial year (in euros)."
    },
    {
      "name": "consolidated_balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The consolidated balance sheet total for the group of linked companies in the financial year (in euros)."
    },
    {
      "name": "combined_average_employees_fte",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The sum of annual average employees in FTE across all linked companies in the financial year."
    },
    {
      "name": "adjusted_turnover_threshold",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "helper",
      "description": "The applicable net turnover threshold, increased by 20% when consolidation eliminations are not applied (in euros)."
    },
    {
      "name": "adjusted_balance_sheet_threshold",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "helper",
      "description": "The applicable balance sheet total threshold, increased by 20% when consolidation eliminations are not applied (in euros)."
    }
