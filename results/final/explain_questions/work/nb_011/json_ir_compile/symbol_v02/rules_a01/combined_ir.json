  "rules": [
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "pred": "employees_registered_in_dimona",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        },
        {
          "compare": {
            "left": {
              "func": "annual_average_employees_fte",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 50.0
          }
        }
      ],
      "then": [
        {
          "pred": "employee_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
