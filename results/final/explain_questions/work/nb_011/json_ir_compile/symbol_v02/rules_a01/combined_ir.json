{
  "types": [
    "Company",
    "FinancialYear"
  ],
  "predicates": [
    {
      "name": "has_legal_personality",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The company has legal personality (rechtspersoonlijkheid).",
      "directly_observable": true
    },
    {
      "name": "employee_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual average employee threshold in the financial year."
    },
    {
      "name": "turnover_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual net turnover threshold (excluding VAT) in the financial year."
    },
    {
      "name": "balance_sheet_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the balance sheet total threshold in the financial year."
    },
    {
      "name": "more_than_one_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds more than one of the three size criteria in the financial year."
    },
    {
      "name": "is_small_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The company qualifies as a kleine vennootschap (small company) on the balance sheet date of the last closed financial year.",
      "legal_output": true,
      "output_category": "classification"
    },
    {
      "name": "is_linked_company",
      "args": [
        "Company",
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The two companies are linked (verbonden) as defined in article 1:20.",
      "directly_observable": true
    },
    {
      "name": "revenues_mostly_non_turnover",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "More than half of the company's ordinary revenues do not qualify as net turnover, triggering the alternative turnover definition.",
      "directly_observable": true
    },
    {
      "name": "consolidation_eliminations_applied",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The required consolidation eliminations and omissions under the relevant royal decree are applied when computing consolidated balance sheet total and net turnover.",
