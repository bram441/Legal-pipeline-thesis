    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "used_false_information_or_documents_in_procedure",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
