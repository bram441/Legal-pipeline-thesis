{
  "types": [
    "Person",
    "Document",
    "Procedure",
    "Measure",
    "MemberState"
  ],
  "predicates": [
    {
      "name": "is_belgian_national",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person can prove they hold Belgian nationality.",
      "directly_observable": true
    },
    {
      "name": "is_foreigner",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is a foreigner (cannot prove Belgian nationality)."
    },
    {
      "name": "is_union_citizen",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is a citizen of the European Union.",
      "directly_observable": true
    },
    {
      "name": "falls_under_free_movement_law",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person falls under EU law on free movement as defined in Article 2(5) of the Schengen Borders Code.",
      "directly_observable": true
    },
    {
      "name": "is_third_country_national",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is a third-country national (not a Union citizen and not covered by free movement law)."
    },
    {
      "name": "meets_entry_or_residence_conditions",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person meets or continues to meet the conditions for entry to or residence on the territory.",
      "directly_observable": true
    },
    {
      "name": "in_illegal_residence",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is in illegal residence on the territory (does not or no longer meets entry/residence conditions)."
    },
    {
      "name": "subject_to_removal_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is subject to a removal procedure.",
      "directly_observable": true
    },
    {
      "name": "subject_to_international_protection_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is subject to a procedure for granting international protection.",
      "directly_observable": true
    },
    {
      "name": "subject_to_responsibility_determination_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is subject to a procedure to determine or transfer to the responsible member state for an international protection request.",
      "directly_observable": true
    },
    {
      "name": "individual_examination_performed",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "An individual examination has been performed for the person.",
      "directly_observable": true
    },
    {
      "name": "holds_valid_travel_document",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person holds a valid travel document, valid passport, or valid identity document.",
      "directly_observable": true
    },
    {
      "name": "recognized_by_national_authority_willing_to_issue_laissez_passer",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person has been recognized as a national by the national authority of their country, which declared willingness to issue a laissez-passer.",
      "directly_observable": true
    },
    {
      "name": "falls_under_nationality_category_for_ministerial_laissez_passer",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person falls under a nationality category for which the minister can issue a laissez-passer.",
      "directly_observable": true
    },
    {
      "name": "is_identified_foreigner",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person qualifies as an identified foreigner under the statutory definition."
    },
    {
      "name": "no_residence_application_filed_after_illegal_entry_or_during_illegal_stay",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person did not file a residence application after illegal entry or during illegal stay, or did not submit an international protection request within the legally prescribed period.",
      "directly_observable": true
    },
    {
      "name": "used_false_misleading_info_or_documents_or_fraud",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person used false or misleading information, false or forged documents, committed fraud, or used other unlawful means in a protection, residence, removal, or pushback procedure.",
      "directly_observable": true
    },
    {
      "name": "does_not_cooperate_with_authorities",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person does not cooperate or has not cooperated with authorities responsible for enforcement or supervision of regulations on entry, residence, establishment, and removal.",
      "directly_observable": true
    },
    {
      "name": "indicated_unwillingness_to_comply_with_measure_or_already_failed_to_comply",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person has indicated unwillingness to comply with, or has already failed to comply with, a transfer, pushback, removal measure, entry ban, less coercive measure, or liberty-restricting measure.",
      "directly_observable": true
    },
    {
      "name": "subject_to_active_entry_ban",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is subject to an entry ban in Belgium and/or another member state that has not been lifted or suspended.",
      "directly_observable": true
    },
    {
      "name": "filed_new_application_immediately_after_negative_decision_or_removal_measure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person filed a new residence application or new international protection request immediately after being subject to a refusal of entry or residence, a decision ending their stay, or a pushback or removal measure.",
      "directly_observable": true
    },
    {
      "name": "concealed_prior_fingerprints_in_other_schengen_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "When questioned on this point, the person concealed that they had previously given fingerprints in another state bound by EU regulations on determining the state responsible for an international protection request.",
      "directly_observable": true
    },
    {
      "name": "multiple_applications_with_negative_or_no_residence_outcome",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person has filed multiple international protection requests and/or residence applications in Belgium or other member states that resulted in negative decisions or did not lead to a residence permit.",
      "directly_observable": true
    },
    {
      "name": "concealed_prior_international_protection_request_in_other_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "When questioned on this point, the person concealed that they had previously filed an international protection request in another state bound by EU regulations on determining the responsible state.",
      "directly_observable": true
    },
    {
      "name": "declared_or_file_shows_entry_for_other_purposes",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person declared or their file shows that they came to Belgium for purposes other than those for which they filed an international protection request or residence application.",
      "directly_observable": true
    },
    {
      "name": "subject_to_fine_for_manifestly_unfounded_appeal",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The person is subject to a fine because they filed a manifestly unfounded appeal with the Council for Alien Law Litigation.",
      "directly_observable": true
    },
    {
      "name": "at_least_one_absconding_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "At least one of the objective criteria for risk of absconding is met for the person."
    },
    {
      "name": "risk_of_absconding",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person presents a current and real risk of absconding as legally defined, established after individual examination on the basis of objective criteria.",
      "legal_output": true,
      "output_category": "classification"
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_belgian_national",
          "args": [
            "p"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_union_citizen",
              "args": [
                "p"
              ],
              "negated": true
            },
            {
              "pred": "falls_under_free_movement_law",
              "args": [
                "p"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "is_third_country_national",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_foreigner",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "meets_entry_or_residence_conditions",
