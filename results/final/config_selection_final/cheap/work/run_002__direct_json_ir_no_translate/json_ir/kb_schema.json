        }
      ],
      "then": [
        {
          "pred": "at_least_one_absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "declared_or_file_shows_entry_for_other_purposes",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "at_least_one_absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "subject_to_fine_for_manifestly_unfounded_appeal",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "at_least_one_absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "and": [
            {
              "pred": "individual_examination_performed",
              "args": [
