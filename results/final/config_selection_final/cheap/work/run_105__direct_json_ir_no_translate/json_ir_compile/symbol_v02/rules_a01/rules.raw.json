{
  "rules": [
    {
      "forall": [
        {"var": "survivor", "type": "Person"},
        {"var": "predeceased", "type": "Person"}
      ],
      "if": [
        {"pred": "is_surviving_cohabiting_partner", "args": ["survivor"], "negated": false},
        {"pred": "is_predeceased_cohabiting_partner", "args": ["predeceased"], "negated": false},
        {"pred": "is_legally_cohabiting_partner_of", "args": ["survivor", "predeceased"], "negated": false},
        {"pred": "is_descendant_of", "args": ["survivor", "predeceased"], "negated": false}
      ],
      "then": [
        {"pred": "exception_applies", "args": ["survivor", "predeceased"], "negated": false}
      ],
      "operator": "implies"
    }
  ]
}