vocabulary V {
  type Person
  type Asset
  is_surviving_spouse_of: Person * Person -> Bool
  deceased_leaves_ascendants: Person -> Bool
  deceased_leaves_close_collaterals: Person -> Bool
  asset_in_common_estate: Asset * Person -> Bool
  asset_in_undivided_between_spouses: Asset * Person -> Bool
  asset_in_own_estate: Asset * Person -> Bool
  asset_subject_to_legal_reversion_4_24: Asset * Person -> Bool
  asset_subject_to_legal_reversion_4_25: Asset * Person -> Bool
  deed_or_testament_excludes_usufruct_on_reversion_asset: Asset * Person -> Bool
  deceased_leaves_ascendants_or_close_collaterals: Person -> Bool
  acquires_full_ownership_of_asset: Person * Asset -> Bool
  acquires_usufruct_of_asset: Person * Asset -> Bool
}

theory T:V {
  ! spouse in Person, deceased in Person: (((deceased_leaves_ascendants(deceased)) | (deceased_leaves_close_collaterals(deceased)))) => ((deceased_leaves_ascendants_or_close_collaterals(deceased))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & (asset_in_common_estate(asset,deceased)))) => ((acquires_full_ownership_of_asset(spouse,asset))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & (asset_in_undivided_between_spouses(asset,deceased)))) => ((acquires_full_ownership_of_asset(spouse,asset))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & (asset_in_own_estate(asset,deceased)) & (~asset_subject_to_legal_reversion_4_24(asset,deceased)) & (~asset_subject_to_legal_reversion_4_25(asset,deceased)))) => ((acquires_usufruct_of_asset(spouse,asset))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & ((asset_subject_to_legal_reversion_4_24(asset,deceased)) | (asset_subject_to_legal_reversion_4_25(asset,deceased))) & (~deed_or_testament_excludes_usufruct_on_reversion_asset(asset,deceased)))) => ((acquires_usufruct_of_asset(spouse,asset))).
}
