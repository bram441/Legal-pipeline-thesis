vocabulary V {
  type Person
  type Asset
  is_surviving_spouse_of: Person * Person -> Bool
  deceased_leaves_ascendants: Person -> Bool
  deceased_leaves_close_collaterals: Person -> Bool
  asset_in_common_estate: Asset * Person -> Bool
  asset_in_undivided_estate_between_spouses: Asset * Person -> Bool
  asset_in_own_estate: Asset * Person -> Bool
  asset_subject_to_legal_reversion_4_24: Asset * Person -> Bool
  asset_subject_to_legal_reversion_4_25: Asset * Person -> Bool
  deed_or_testament_excludes_usufruct_on_reversion_asset: Asset * Person -> Bool
  deceased_leaves_ascendants_or_close_collaterals: Person -> Bool
  asset_in_common_or_undivided_estate: Asset * Person -> Bool
  asset_subject_to_legal_reversion: Asset * Person -> Bool
  surviving_spouse_acquires_full_ownership: Person * Asset -> Bool
  surviving_spouse_acquires_usufruct: Person * Asset -> Bool
}

theory T:V {
  ! deceased in Person: (((deceased_leaves_ascendants(deceased)) | (deceased_leaves_close_collaterals(deceased)))) => ((deceased_leaves_ascendants_or_close_collaterals(deceased))).
  ! asset in Asset, deceased in Person: (((asset_in_common_estate(asset,deceased)) | (asset_in_undivided_estate_between_spouses(asset,deceased)))) => ((asset_in_common_or_undivided_estate(asset,deceased))).
  ! asset in Asset, deceased in Person: (((asset_subject_to_legal_reversion_4_24(asset,deceased)) | (asset_subject_to_legal_reversion_4_25(asset,deceased)))) => ((asset_subject_to_legal_reversion(asset,deceased))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & (asset_in_common_or_undivided_estate(asset,deceased)))) => ((surviving_spouse_acquires_full_ownership(spouse,asset))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & (asset_in_own_estate(asset,deceased)) & (~asset_subject_to_legal_reversion(asset,deceased)))) => ((surviving_spouse_acquires_usufruct(spouse,asset))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & (asset_subject_to_legal_reversion(asset,deceased)) & (~deed_or_testament_excludes_usufruct_on_reversion_asset(asset,deceased)))) => ((surviving_spouse_acquires_usufruct(spouse,asset))).
}
