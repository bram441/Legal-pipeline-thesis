{
  "types": [
    "Company",
    "FinancialYear"
  ],
  "predicates": [
    {
      "name": "has_legal_personality",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company has legal personality (rechtspersoonlijkheid). This is a background status that may be directly asserted from case facts."
    },
    {
      "name": "is_startup_year",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The financial year is the first year in which the company starts its business."
    },
    {
      "name": "good_faith_estimate_exceeds_employee_criterion",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "A good-faith estimate at the start of the financial year indicates the employee criterion will be exceeded during the first financial year."
    },
    {
      "name": "good_faith_estimate_exceeds_turnover_criterion",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "A good-faith estimate at the start of the financial year indicates the turnover criterion will be exceeded during the first financial year."
    },
    {
      "name": "good_faith_estimate_exceeds_balance_sheet_criterion",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "A good-faith estimate at the start of the financial year indicates the balance sheet criterion will be exceeded during the first financial year."
    },
    {
      "name": "employee_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual average employee threshold in the financial year."
    },
    {
      "name": "turnover_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual net turnover threshold (excluding VAT) in the financial year."
    },
    {
      "name": "balance_sheet_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the balance sheet total threshold in the financial year."
    },
    {
      "name": "more_than_one_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds more than one of the three statutory criteria in the financial year."
    },
    {
      "name": "good_faith_estimate_exceeds_more_than_one_criterion",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "A good-faith estimate at the start of the first financial year indicates more than one criterion will be exceeded."
    },
    {
      "name": "is_kleine_vennootschap",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "legal_output": true,
      "output_category": "classification",
      "description": "The company qualifies as a kleine vennootschap (small company) for the given financial year."
    }
  ],
  "functions": [
    {
      "name": "annual_average_employees",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Int",
      "kind": "observable",
      "description": "The annual average number of employees of the company in the financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover excluding VAT of the company in the financial year, as referred to in article 1:26/1."
    },
    {
      "name": "balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The balance sheet total of the company in the financial year."
    }
  ],
  "rules": [
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "annual_average_employees",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 50
          }
        }
      ],
      "then": [
        {
          "pred": "employee_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "annual_net_turnover_excl_vat",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 11250000.0
          }
        }
      ],
      "then": [
        {
          "pred": "turnover_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "fy",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "compare": {
            "left": {
              "func": "balance_sheet_total",
              "args": [
                "c",
                "fy"
              ]
            },
            "op": ">",
            "right": 6000000.0
          }
        }
      ],
      "then": [
        {
          "pred": "balance_sheet_criterion_exceeded",
          "args": [
            "c",
            "fy"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
