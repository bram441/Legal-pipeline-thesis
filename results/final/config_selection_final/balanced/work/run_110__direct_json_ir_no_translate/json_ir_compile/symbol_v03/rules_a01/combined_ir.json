{
  "types": [
    "Person",
    "Document",
    "Procedure",
    "Measure",
    "MemberState"
  ],
  "predicates": [
    {
      "name": "is_foreigner",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person cannot prove Belgian nationality and is therefore a foreigner."
    },
    {
      "name": "has_belgian_nationality",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person has Belgian nationality, as directly stated or proven in the case."
    },
    {
      "name": "is_third_country_national",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is a national of a third country (not an EU citizen and not covered by EU free movement law)."
    },
    {
      "name": "is_eu_citizen",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is a citizen of the European Union."
    },
    {
      "name": "covered_by_eu_free_movement_law",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person falls under EU law on free movement as defined in Article 2(5) of the Schengen Borders Code."
    },
    {
      "name": "in_illegal_residence",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person is present on the territory without meeting or no longer meeting the conditions for access or residence."
    },
    {
      "name": "meets_entry_or_residence_conditions",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The person meets the conditions for access to or residence on the territory. Intermediate condition used to derive illegal residence status."
    },
    {
      "name": "subject_to_removal_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is subject to a removal procedure."
    },
    {
      "name": "subject_to_international_protection_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is subject to a procedure for granting international protection."
    },
    {
      "name": "subject_to_responsibility_determination_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is subject to a procedure to determine or transfer to the responsible member state for an international protection request."
    },
    {
      "name": "risk_of_absconding",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "There is a current and real risk that the person will abscond, established after individual examination based on objective criteria."
    },
    {
      "name": "individual_examination_performed",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "An individual examination of the person's situation has been performed."
    },
    {
      "name": "has_valid_travel_document",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person holds a valid travel document, valid passport, or valid identity document."
    },
    {
      "name": "recognized_by_national_authority_of_origin",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person has been recognized as a national by the national authority of their country, which declared willingness to issue a laissez-passer."
    },
    {
      "name": "falls_under_nationality_category_for_ministerial_laissez_passer",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person falls under a nationality category for which the minister can issue a laissez-passer directly."
    },
    {
      "name": "is_identified_foreigner",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The person qualifies as an identified foreigner under the statutory definition."
    },
    {
      "name": "no_residence_application_filed_after_illegal_entry_or_during_illegal_stay",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person did not file a residence application after illegal entry or during illegal stay, or did not submit an international protection request within the legally prescribed period."
    },
    {
      "name": "used_false_information_or_documents_in_procedure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person used false or misleading information, false or forged documents, committed fraud, or used other unlawful means in a procedure for international protection, residence, removal, or pushback."
    },
    {
      "name": "does_not_cooperate_with_authorities",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person does not cooperate or has not cooperated with authorities responsible for enforcement or supervision of regulations on access, residence, establishment, and removal of foreigners."
    },
    {
      "name": "indicated_unwillingness_to_comply_with_measure",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person has clearly indicated unwillingness to comply with, or has already failed to comply with, a transfer, pushback, removal measure, entry ban, less coercive measure, or liberty-restricting measure."
    },
    {
      "name": "subject_to_active_entry_ban",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is subject to an entry ban in Belgium and/or another member state that has not been lifted or suspended."
    },
    {
      "name": "filed_new_application_immediately_after_negative_decision",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person filed a new residence application or new international protection request immediately after being subject to a refusal of entry or residence, a decision ending their stay, or a pushback or removal measure."
    },
    {
      "name": "concealed_prior_fingerprints_in_other_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "When questioned on the matter, the person concealed that they had previously given fingerprints in another state bound by EU regulations on determining the state responsible for an international protection request."
    },
    {
      "name": "multiple_applications_with_negative_outcomes_in_member_states",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person has submitted multiple international protection requests and/or residence applications in Belgium or other member states that resulted in negative decisions or did not lead to a residence permit."
    },
    {
      "name": "concealed_prior_international_protection_request_in_other_state",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "When questioned on the matter, the person concealed that they had previously submitted an international protection request in another state bound by EU regulations on determining the responsible state."
    },
    {
      "name": "came_for_purposes_other_than_stated_in_application",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person declared or their file shows that they came to Belgium for purposes other than those for which they submitted an international protection request or residence application."
    },
    {
      "name": "fined_for_manifestly_unfounded_appeal",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The person is subject to a fine because they filed a manifestly unlawful appeal with the Council for Alien Law Litigation."
    },
    {
      "name": "absconding_criterion_met",
      "args": [
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "At least one of the statutory objective criteria for risk of absconding is met for the person."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "has_belgian_nationality",
          "args": [
            "p"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "pred": "is_eu_citizen",
          "args": [
            "p"
          ],
          "negated": true
        },
        {
          "pred": "covered_by_eu_free_movement_law",
          "args": [
            "p"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "is_third_country_national",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "pred": "meets_entry_or_residence_conditions",
          "args": [
            "p"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "in_illegal_residence",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "or": [
            {
              "pred": "subject_to_removal_procedure",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "subject_to_international_protection_procedure",
              "args": [
                "p"
              ],
              "negated": false
            },
            {
              "pred": "subject_to_responsibility_determination_procedure",
              "args": [
                "p"
              ],
              "negated": false
            }
          ]
        },
        {
          "pred": "individual_examination_performed",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "risk_of_absconding",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "no_residence_application_filed_after_illegal_entry_or_during_illegal_stay",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "used_false_information_or_documents_in_procedure",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "does_not_cooperate_with_authorities",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "indicated_unwillingness_to_comply_with_measure",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "subject_to_active_entry_ban",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "filed_new_application_immediately_after_negative_decision",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "concealed_prior_fingerprints_in_other_state",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "multiple_applications_with_negative_outcomes_in_member_states",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "concealed_prior_international_protection_request_in_other_state",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "came_for_purposes_other_than_stated_in_application",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "fined_for_manifestly_unfounded_appeal",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "absconding_criterion_met",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "pred": "has_valid_travel_document",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "pred": "recognized_by_national_authority_of_origin",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "p",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        },
        {
          "pred": "falls_under_nationality_category_for_ministerial_laissez_passer",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_identified_foreigner",
          "args": [
            "p"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    }
  ]
}