{
  "rules": [
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"compare": {"left": {"func": "annual_average_employees", "args": ["c", "fy"]}, "op": ">", "right": 50}}
      ],
      "then": [
        {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"compare": {"left": {"func": "annual_net_turnover_excl_vat", "args": ["c", "fy"]}, "op": ">", "right": 11250000.0}}
      ],
      "then": [
        {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"compare": {"left": {"func": "balance_sheet_total", "args": ["c", "fy"]}, "op": ">", "right": 6000000.0}}
      ],
      "then": [
        {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"and": [
          {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false},
          {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"and": [
          {"pred": "employee_criterion_exceeded", "args": ["c", "fy"], "negated": false},
          {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "fy"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"and": [
          {"pred": "turnover_criterion_exceeded", "args": ["c", "fy"], "negated": false},
          {"pred": "balance_sheet_criterion_exceeded", "args": ["c", "fy"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"},
        {"var": "fy_prev", "type": "FinancialYear"}
      ],
      "if": [
        {"and": [
          {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": false},
          {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy_prev"], "negated": false},
          {"pred": "previous_financial_year", "args": ["fy", "fy_prev"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded_two_consecutive_years", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"},
        {"var": "fy_prev", "type": "FinancialYear"}
      ],
      "if": [
        {"and": [
          {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": true},
          {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy_prev"], "negated": true},
          {"pred": "previous_financial_year", "args": ["fy", "fy_prev"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "ceases_to_exceed_more_than_one_criterion_two_consecutive_years", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy_second", "type": "FinancialYear"},
        {"var": "fy_effect", "type": "FinancialYear"}
      ],
      "if": [
        {"and": [
          {"pred": "more_than_one_criterion_exceeded_two_consecutive_years", "args": ["c", "fy_second"], "negated": false},
          {"pred": "next_financial_year", "args": ["fy_second", "fy_effect"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "loses_kleine_vennootschap_status_from", "args": ["c", "fy_effect"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy_second", "type": "FinancialYear"},
        {"var": "fy_effect", "type": "FinancialYear"}
      ],
      "if": [
        {"and": [
          {"pred": "ceases_to_exceed_more_than_one_criterion_two_consecutive_years", "args": ["c", "fy_second"], "negated": false},
          {"pred": "next_financial_year", "args": ["fy_second", "fy_effect"], "negated": false}
        ]}
      ],
      "then": [
        {"pred": "gains_kleine_vennootschap_status_from", "args": ["c", "fy_effect"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"and": [
          {"pred": "has_legal_personality", "args": ["c"], "negated": false},
          {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": true}
        ]}
      ],
      "then": [
        {"pred": "is_kleine_vennootschap", "args": ["c", "fy"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {"var": "c", "type": "Company"},
        {"var": "fy", "type": "FinancialYear"}
      ],
      "if": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "fy"], "negated": false}
      ],
      "then": [
        {"pred": "is_kleine_vennootschap", "args": ["c", "fy"], "negated": true}
      ],
      "operator": "implies"
    }
  ]
