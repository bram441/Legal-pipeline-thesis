vocabulary V {
  type Person
  type Estate
  is_surviving_spouse_of: Person * Person -> Bool
  deceased_leaves_descendants: Person -> Bool
  deceased_leaves_adopted_children: Person -> Bool
  deceased_leaves_descendants_of_adopted_children: Person -> Bool
  estate_belongs_to: Estate * Person -> Bool
  qualifying_descendants_or_adopted_exist: Person -> Bool
  receives_usufruct_of_entire_estate: Person * Estate -> Bool
}

theory T:V {
  ! deceased in Person: (((deceased_leaves_descendants(deceased)) | (deceased_leaves_adopted_children(deceased)) | (deceased_leaves_descendants_of_adopted_children(deceased)))) => ((qualifying_descendants_or_adopted_exist(deceased))).
  ! spouse in Person, deceased in Person, estate in Estate: (((is_surviving_spouse_of(spouse,deceased)) & (qualifying_descendants_or_adopted_exist(deceased)) & (estate_belongs_to(estate,deceased)))) => ((receives_usufruct_of_entire_estate(spouse,estate))).
}
