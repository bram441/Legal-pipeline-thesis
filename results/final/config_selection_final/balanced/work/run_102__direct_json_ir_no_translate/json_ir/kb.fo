vocabulary V {
  type Person
  type Asset
  is_surviving_spouse_of: Person * Person -> Bool
  deceased_leaves_ascendants: Person -> Bool
  deceased_leaves_close_collaterals: Person -> Bool
  asset_in_common_estate: Asset * Person -> Bool
  asset_in_undivided_estate_between_spouses: Asset * Person -> Bool
  asset_in_own_estate: Asset * Person -> Bool
  asset_subject_to_legal_reversion_4_24: Asset * Person -> Bool
  asset_subject_to_legal_reversion_4_25: Asset * Person -> Bool
  deed_of_gift_excludes_usufruct: Asset * Person -> Bool
  testament_excludes_usufruct: Asset * Person -> Bool
  deceased_leaves_ascendants_or_close_collaterals: Person -> Bool
  asset_in_common_or_undivided_estate: Asset * Person -> Bool
  asset_subject_to_legal_reversion: Asset * Person -> Bool
  usufruct_on_reversion_asset_excluded: Asset * Person -> Bool
  acquires_full_ownership: Person * Asset -> Bool
  acquires_usufruct: Person * Asset -> Bool
}

theory T:V {
  ! spouse in Person, deceased in Person: (((deceased_leaves_ascendants(deceased)) | (deceased_leaves_close_collaterals(deceased)))) => ((deceased_leaves_ascendants_or_close_collaterals(deceased))).
  ! asset in Asset, deceased in Person: (((asset_in_common_estate(asset,deceased)) | (asset_in_undivided_estate_between_spouses(asset,deceased)))) => ((asset_in_common_or_undivided_estate(asset,deceased))).
  ! asset in Asset, deceased in Person: (((asset_subject_to_legal_reversion_4_24(asset,deceased)) | (asset_subject_to_legal_reversion_4_25(asset,deceased)))) => ((asset_subject_to_legal_reversion(asset,deceased))).
  ! asset in Asset, deceased in Person: (((asset_subject_to_legal_reversion(asset,deceased)) & ((deed_of_gift_excludes_usufruct(asset,deceased)) | (testament_excludes_usufruct(asset,deceased))))) => ((usufruct_on_reversion_asset_excluded(asset,deceased))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & (asset_in_common_or_undivided_estate(asset,deceased)))) => ((acquires_full_ownership(spouse,asset))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & (asset_in_own_estate(asset,deceased)) & (~asset_subject_to_legal_reversion(asset,deceased)))) => ((acquires_usufruct(spouse,asset))).
  ! spouse in Person, deceased in Person, asset in Asset: (((is_surviving_spouse_of(spouse,deceased)) & (deceased_leaves_ascendants_or_close_collaterals(deceased)) & (asset_subject_to_legal_reversion(asset,deceased)) & (~usufruct_on_reversion_asset_excluded(asset,deceased)))) => ((acquires_usufruct(spouse,asset))).
}
