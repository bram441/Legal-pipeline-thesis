      ],
      "if": [
        {
          "and": [
            {
              "pred": "is_surviving_spouse_of",
              "args": [
                "spouse",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "deceased_leaves_ascendants_or_close_collaterals",
              "args": [
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "asset_in_own_estate",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": false
            },
            {
              "pred": "asset_subject_to_legal_reversion",
              "args": [
                "asset",
                "deceased"
              ],
              "negated": true
            }
          ]
        }
      ],
      "then": [
