vocabulary V {
  type Person
  type Document
  type MemberState
  type Procedure
  is_belgian_national: Person -> Bool
  is_foreigner: Person -> Bool
  is_eu_citizen: Person -> Bool
  falls_under_eu_free_movement_law: Person -> Bool
  is_third_country_national: Person -> Bool
  meets_entry_or_residence_conditions: Person -> Bool
  in_illegal_residence: Person -> Bool
  subject_to_removal_procedure: Person -> Bool
  subject_to_international_protection_procedure: Person -> Bool
  subject_to_responsibility_determination_procedure: Person -> Bool
  holds_valid_travel_document: Person -> Bool
  recognised_as_national_by_home_country: Person -> Bool
  nationality_covered_by_ministerial_laissez_passer: Person -> Bool
  is_identified_foreigner: Person -> Bool
  individual_examination_performed: Person -> Bool
  risk_of_absconding_is_current_and_real: Person -> Bool
  criterion_no_residence_application_filed: Person -> Bool
  criterion_used_false_information_or_fraud: Person -> Bool
  criterion_non_cooperation_with_authorities: Person -> Bool
  criterion_indicated_or_failed_to_comply_with_measure: Person -> Bool
  criterion_subject_to_entry_ban: Person -> Bool
  criterion_new_application_after_negative_decision: Person -> Bool
  criterion_concealed_fingerprints_in_other_state: Person -> Bool
  criterion_multiple_applications_with_negative_outcome: Person -> Bool
  criterion_concealed_prior_protection_request_in_other_state: Person -> Bool
  criterion_came_for_other_purposes_than_stated: Person -> Bool
  criterion_fined_for_manifestly_unfounded_appeal: Person -> Bool
  at_least_one_absconding_criterion_met: Person -> Bool
  risk_of_absconding: Person -> Bool
}

theory T:V {
  ! p in Person: ((~is_belgian_national(p))) => ((is_foreigner(p))).
  ! p in Person: (((~is_eu_citizen(p)) & (~falls_under_eu_free_movement_law(p)))) => ((is_third_country_national(p))).
  ! p in Person: (((is_foreigner(p)) & (~meets_entry_or_residence_conditions(p)))) => ((in_illegal_residence(p))).
  ! p in Person: ((holds_valid_travel_document(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((recognised_as_national_by_home_country(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((nationality_covered_by_ministerial_laissez_passer(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((criterion_no_residence_application_filed(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_used_false_information_or_fraud(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_non_cooperation_with_authorities(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_indicated_or_failed_to_comply_with_measure(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_subject_to_entry_ban(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_new_application_after_negative_decision(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_concealed_fingerprints_in_other_state(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_multiple_applications_with_negative_outcome(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_concealed_prior_protection_request_in_other_state(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_came_for_other_purposes_than_stated(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: ((criterion_fined_for_manifestly_unfounded_appeal(p))) => ((at_least_one_absconding_criterion_met(p))).
  ! p in Person: (((at_least_one_absconding_criterion_met(p)) & (individual_examination_performed(p)) & (risk_of_absconding_is_current_and_real(p)) & ((subject_to_removal_procedure(p)) | (subject_to_international_protection_procedure(p)) | (subject_to_responsibility_determination_procedure(p))))) => ((risk_of_absconding(p))).
  ! p in Person: (((at_least_one_absconding_criterion_met(p)) & (individual_examination_performed(p)) & ((subject_to_removal_procedure(p)) | (subject_to_international_protection_procedure(p)) | (subject_to_responsibility_determination_procedure(p))))) => ((risk_of_absconding_is_current_and_real(p))).
}
