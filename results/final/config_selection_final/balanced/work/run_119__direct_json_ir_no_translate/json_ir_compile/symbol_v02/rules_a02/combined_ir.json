{
  "types": [
    "Company",
    "FinancialYear"
  ],
  "predicates": [
    {
      "name": "has_legal_personality",
      "args": [
        "Company"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company has legal personality (rechtspersoonlijkheid). This is a background status that may be directly asserted from case facts."
    },
    {
      "name": "is_starting_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "The company is starting its business in the given financial year (first financial year)."
    },
    {
      "name": "good_faith_estimate_shows_more_than_one_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "observable",
      "directly_observable": true,
      "description": "A good-faith estimate at the start of the financial year shows that more than one criterion will be exceeded during the first financial year."
    },
    {
      "name": "employee_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual average employee threshold of 50 in the financial year."
    },
    {
      "name": "turnover_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the annual net turnover threshold of 11,250,000 EUR (excluding VAT) in the financial year."
    },
    {
      "name": "balance_sheet_threshold_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds the balance sheet total threshold of 6,000,000 EUR in the financial year."
    },
    {
      "name": "more_than_one_criterion_exceeded",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The company exceeds more than one of the three statutory criteria in the financial year."
    },
    {
      "name": "is_small_company",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Bool",
      "kind": "derived",
      "output_category": "classification",
      "description": "The company qualifies as a small company (kleine vennootschap) on the balance sheet date of the last closed financial year."
    }
  ],
  "functions": [
    {
      "name": "annual_average_employees",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Int",
      "kind": "observable",
      "description": "The annual average number of employees of the company in the financial year."
    },
    {
      "name": "annual_net_turnover_excl_vat",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The annual net turnover excluding VAT of the company in the financial year, as referred to in article 1:26/1."
    },
    {
      "name": "balance_sheet_total",
      "args": [
        "Company",
        "FinancialYear"
      ],
      "returns": "Real",
      "kind": "observable",
      "description": "The balance sheet total of the company in the financial year."
    }
  ],
  "rules": [
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "left": {
            "func": "annual_average_employees",
            "args": [
              "c",
              "y"
            ]
          },
          "op": ">",
          "right": 50
        }
      ],
      "then": [
        {
          "pred": "employee_threshold_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "left": {
            "func": "annual_net_turnover_excl_vat",
            "args": [
              "c",
              "y"
            ]
          },
          "op": ">",
          "right": 11250000
        }
      ],
      "then": [
        {
          "pred": "turnover_threshold_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "left": {
            "func": "balance_sheet_total",
            "args": [
              "c",
              "y"
            ]
          },
          "op": ">",
          "right": 6000000
        }
      ],
      "then": [
        {
          "pred": "balance_sheet_threshold_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "or": [
            {
              "and": [
                {
                  "pred": "employee_threshold_exceeded",
                  "args": [
                    "c",
                    "y"
                  ],
                  "negated": false
                },
                {
                  "pred": "turnover_threshold_exceeded",
                  "args": [
                    "c",
                    "y"
                  ],
                  "negated": false
                }
              ]
            },
            {
              "and": [
                {
                  "pred": "employee_threshold_exceeded",
                  "args": [
                    "c",
                    "y"
                  ],
                  "negated": false
                },
                {
                  "pred": "balance_sheet_threshold_exceeded",
                  "args": [
                    "c",
                    "y"
                  ],
                  "negated": false
                }
              ]
            },
            {
              "and": [
                {
                  "pred": "turnover_threshold_exceeded",
                  "args": [
                    "c",
                    "y"
                  ],
                  "negated": false
                },
                {
                  "pred": "balance_sheet_threshold_exceeded",
                  "args": [
                    "c",
                    "y"
                  ],
                  "negated": false
                }
              ]
            }
          ]
        }
      ],
      "then": [
        {
          "pred": "more_than_one_criterion_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "pred": "has_legal_personality",
          "args": [
            "c"
          ],
          "negated": false
        },
        {
          "pred": "more_than_one_criterion_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": true
        },
        {
          "pred": "is_starting_company",
          "args": [
            "c",
            "y"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "is_small_company",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "pred": "has_legal_personality",
          "args": [
            "c"
          ],
          "negated": false
        },
        {
          "pred": "is_starting_company",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        },
        {
          "pred": "good_faith_estimate_shows_more_than_one_criterion_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "is_small_company",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "pred": "more_than_one_criterion_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_small_company",
          "args": [
            "c",
            "y"
          ],
          "negated": true
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "c",
          "type": "Company"
        },
        {
          "var": "y",
          "type": "FinancialYear"
        }
      ],
      "if": [
        {
          "pred": "is_starting_company",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        },
        {
          "pred": "good_faith_estimate_shows_more_than_one_criterion_exceeded",
          "args": [
            "c",
            "y"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "is_small_company",
          "args": [
            "c",
            "y"
          ],
          "negated": true
        }
      ],
      "operator": "implies"
    }
  ]
}