{
  "rules": [
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"left": {"func": "annual_average_employees", "args": ["c", "y"]}, "op": ">", "right": 50}
      ],
      "then": [
        {"pred": "employee_threshold_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"left": {"func": "annual_net_turnover_excl_vat", "args": ["c", "y"]}, "op": ">", "right": 11250000}
      ],
      "then": [
        {"pred": "turnover_threshold_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"left": {"func": "balance_sheet_total", "args": ["c", "y"]}, "op": ">", "right": 6000000}
      ],
      "then": [
        {"pred": "balance_sheet_threshold_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"or": [
          {"and": [
            {"pred": "employee_threshold_exceeded", "args": ["c", "y"], "negated": false},
            {"pred": "turnover_threshold_exceeded", "args": ["c", "y"], "negated": false}
          ]},
          {"and": [
            {"pred": "employee_threshold_exceeded", "args": ["c", "y"], "negated": false},
            {"pred": "balance_sheet_threshold_exceeded", "args": ["c", "y"], "negated": false}
          ]},
          {"and": [
            {"pred": "turnover_threshold_exceeded", "args": ["c", "y"], "negated": false},
            {"pred": "balance_sheet_threshold_exceeded", "args": ["c", "y"], "negated": false}
          ]}
        ]}
      ],
      "then": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "has_legal_personality", "args": ["c"], "negated": false},
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": true},
        {"pred": "is_starting_company", "args": ["c", "y"], "negated": true}
      ],
      "then": [
        {"pred": "is_small_company", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "has_legal_personality", "args": ["c"], "negated": false},
        {"pred": "is_starting_company", "args": ["c", "y"], "negated": false},
        {"pred": "good_faith_estimate_shows_more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": true}
      ],
      "then": [
        {"pred": "is_small_company", "args": ["c", "y"], "negated": false}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "then": [
        {"pred": "is_small_company", "args": ["c", "y"], "negated": true}
      ],
      "operator": "implies"
    },
    {
      "forall": [{"var": "c", "type": "Company"}, {"var": "y", "type": "FinancialYear"}],
      "if": [
        {"pred": "is_starting_company", "args": ["c", "y"], "negated": false},
        {"pred": "good_faith_estimate_shows_more_than_one_criterion_exceeded", "args": ["c", "y"], "negated": false}
      ],
      "then": [
        {"pred": "is_small_company", "args": ["c", "y"], "negated": true}
      ],
      "operator": "implies"
    }
  ]
}