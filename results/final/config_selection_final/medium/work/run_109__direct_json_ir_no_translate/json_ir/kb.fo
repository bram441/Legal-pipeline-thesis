vocabulary V {
  type Person
  type Document
  type Procedure
  type Measure
  type MemberState
  is_foreigner: Person -> Bool
  holds_belgian_nationality: Person -> Bool
  is_eu_citizen: Person -> Bool
  falls_under_eu_free_movement_law: Person -> Bool
  is_third_country_national: Person -> Bool
  meets_entry_or_residence_conditions: Person -> Bool
  in_illegal_residence: Person -> Bool
  subject_to_removal_procedure: Person -> Bool
  subject_to_international_protection_procedure: Person -> Bool
  subject_to_responsibility_determination_procedure: Person -> Bool
  risk_of_absconding: Person -> Bool
  individual_examination_performed: Person -> Bool
  holds_valid_travel_document: Person -> Bool
  recognised_as_national_by_home_authority: Person -> Bool
  falls_under_nationality_category_for_ministerial_laissez_passer: Person -> Bool
  is_identified_foreigner: Person -> Bool
  no_residence_application_filed_after_illegal_entry_or_during_illegal_stay: Person -> Bool
  used_false_information_or_documents_in_procedure: Person -> Bool
  failed_to_cooperate_with_authorities: Person -> Bool
  indicated_unwillingness_to_comply_with_measure: Person -> Bool
  subject_to_active_entry_ban: Person -> Bool
  filed_new_application_immediately_after_negative_decision: Person -> Bool
  concealed_prior_fingerprints_in_other_state: Person -> Bool
  multiple_applications_with_negative_outcomes_in_member_states: Person -> Bool
  concealed_prior_protection_request_in_other_state: Person -> Bool
  came_for_purposes_other_than_stated_application: Person -> Bool
  subject_to_fine_for_manifestly_unfounded_appeal: Person -> Bool
  absconding_criterion_met: Person -> Bool
}

theory T:V {
  ! p in Person: ((~holds_belgian_nationality(p))) => ((is_foreigner(p))).
  ! p in Person: ((~is_eu_citizen(p)) & (~falls_under_eu_free_movement_law(p))) => ((is_third_country_national(p))).
  ! p in Person: ((is_foreigner(p)) & (~meets_entry_or_residence_conditions(p))) => ((in_illegal_residence(p))).
  ! p in Person: ((holds_valid_travel_document(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((recognised_as_national_by_home_authority(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((falls_under_nationality_category_for_ministerial_laissez_passer(p))) => ((is_identified_foreigner(p))).
  ! p in Person: ((no_residence_application_filed_after_illegal_entry_or_during_illegal_stay(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((used_false_information_or_documents_in_procedure(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((failed_to_cooperate_with_authorities(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((indicated_unwillingness_to_comply_with_measure(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((subject_to_active_entry_ban(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((filed_new_application_immediately_after_negative_decision(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((concealed_prior_fingerprints_in_other_state(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((multiple_applications_with_negative_outcomes_in_member_states(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((concealed_prior_protection_request_in_other_state(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((came_for_purposes_other_than_stated_application(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((subject_to_fine_for_manifestly_unfounded_appeal(p))) => ((absconding_criterion_met(p))).
  ! p in Person: ((((subject_to_removal_procedure(p)) | (subject_to_international_protection_procedure(p)) | (subject_to_responsibility_determination_procedure(p))) & (individual_examination_performed(p)) & (absconding_criterion_met(p)))) => ((risk_of_absconding(p))).
}
