{
  "types": [
    "Person"
  ],
  "predicates": [
    {
      "name": "is_surviving_legal_cohabitant_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is the surviving legal cohabitant of the second (predeceased) person.",
      "directly_observable": true
    },
    {
      "name": "is_descendant_of",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "observable",
      "description": "The first person is a descendant of the second person.",
      "directly_observable": true
    },
    {
      "name": "preceding_provisions_apply",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "derived",
      "description": "The preceding provisions apply to the surviving legal cohabitant in relation to the predeceased legal cohabitant.",
      "legal_output": true
    },
    {
      "name": "exception_descendant_cohabitant",
      "args": [
        "Person",
        "Person"
      ],
      "returns": "Bool",
      "kind": "helper",
      "description": "The exception applies because the surviving legal cohabitant is a descendant of the predeceased legal cohabitant, excluding the preceding provisions."
    }
  ],
  "functions": [],
  "rules": [
    {
      "forall": [
        {
          "var": "survivor",
          "type": "Person"
        },
        {
          "var": "predeceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_surviving_legal_cohabitant_of",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": false
        },
        {
          "pred": "is_descendant_of",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "exception_descendant_cohabitant",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "survivor",
          "type": "Person"
        },
        {
          "var": "predeceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "is_surviving_legal_cohabitant_of",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": false
        },
        {
          "pred": "exception_descendant_cohabitant",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": true
        }
      ],
      "then": [
        {
          "pred": "preceding_provisions_apply",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": false
        }
      ],
      "operator": "implies"
    },
    {
      "forall": [
        {
          "var": "survivor",
          "type": "Person"
        },
        {
          "var": "predeceased",
          "type": "Person"
        }
      ],
      "if": [
        {
          "pred": "exception_descendant_cohabitant",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": false
        }
      ],
      "then": [
        {
          "pred": "preceding_provisions_apply",
          "args": [
            "survivor",
            "predeceased"
          ],
          "negated": true
        }
      ],
      "operator": "implies"
    }
  ]
}