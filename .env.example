# Copy to .env and fill in secrets (never commit .env).

# --- OpenRouter (recommended for thesis model comparison) ---
LLM_PROVIDER=openrouter
LLM_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_API_KEY=your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- OpenAI direct (alternative) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-key-here
# LLM_MODEL=gpt-4.1-mini

# Optional: separate model for NL explanation paraphrase (OpenRouter id or OpenAI model)
# OPENAI_EXPLAINER_MODEL=gpt-5.5

# Optional pipeline toggles
# PIPELINE_USE_LLM_EXPLANATIONS=0
# PIPELINE_DEBUG=0
